@page
@model LoginModel

@{
    ViewData["Title"] = "Inloggen";
}

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-card-header">
            <div class="auth-logo">Echo</div>
            <p class="auth-tagline">Participatieplatform</p>
        </div>

        <div class="auth-card-body">
            <h2 class="fs-5 fw-bold mb-1">Welkom terug</h2>
            <p class="text-muted small mb-4">Log in met je account om verder te gaan.</p>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <form id="account" method="post">
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email"
                           class="form-control"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="naam@voorbeeld.be" />
                    <label asp-for="Input.Email">E-mailadres</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password"
                           class="form-control"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="Wachtwoord" />
                    <label asp-for="Input.Password">Wachtwoord</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label fw-normal text-muted small" asp-for="Input.RememberMe">
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                <div class="d-grid">
                    <button id="login-submit" type="submit" class="btn btn-primary btn-lg fw-semibold">
                        Inloggen
                    </button>
                </div>
            </form>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="auth-divider"><span>of log in met</span></div>
                <form id="external-account"
                      asp-page="./ExternalLogin"
                      asp-route-returnUrl="@Model.ReturnUrl"
                      method="post">
                    <div class="d-grid gap-2">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit"
                                    class="btn btn-outline-secondary"
                                    name="provider"
                                    value="@provider.Name">
                                @provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            }

            <div class="auth-links text-center mt-3">
                <a id="forgot-password" asp-page="./ForgotPassword">Wachtwoord vergeten?</a>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
