@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
        <h4 class="mb-0">@ViewData["Title"]</h4>
    </div>
    <div class="card-body">
        <partial name="_StatusMessage" for="StatusMessage"/>
        
        <div class="row">
            <div class="col-lg-10">
                <form id="profile-form" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control" placeholder="Please choose your username." disabled/>
                        <label asp-for="Username" class="form-label"></label>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Input.LogoFile" class="form-label fw-bold">Subplatform Logo</label>
                        <input asp-for="Input.LogoFile" type="file" class="form-control" accept="image/*"/>
                        <span asp-validation-for="Input.LogoFile" class="text-danger small"></span>
                    </div>

                    <button id="update-profile-button" type="submit" class="btn btn-primary w-100">Save changes</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}