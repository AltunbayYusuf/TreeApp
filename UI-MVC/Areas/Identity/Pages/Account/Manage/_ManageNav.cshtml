@using IntegratieProject.BL.Domain.users
@using IntegratieProject.DAL.Identity
@using IntegratieProject.UI.MVC
@inject SignInManager<ApplicationUser> SignInManager

<div class="card shadow-sm border-0">
    <div class="card-body p-2">
        <ul class="nav nav-pills flex-column gap-1">
            <li class="nav-item">
                <a class="nav-link px-3 py-2 rounded-3 @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="/Account/Manage/Index">
                    Profile
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link px-3 py-2 rounded-3 @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="/Account/Manage/ChangePassword">
                    Password
                </a>
            </li>

            @if (User.IsInRole(CustomIdentityConstants.GeneralAdminRoleName))
            {
                <li class="nav-item">
                    <a class="nav-link px-3 py-2 rounded-3 @ManageNavPages.RegisterNavClass(ViewContext)" id="register" asp-area="Identity" asp-page="/Account/Register">
                        Maak nieuwe subadmin
                    </a>
                </li>
            }
        </ul>
    </div>
</div>