@page
@using IntegratieProject.UI.MVC
@using IntegratieProject.UI.MVC.Areas.Identity.Pages.Account.Manage
@using Microsoft.AspNetCore.Mvc.Rendering;
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    ViewData["ActivePage"] = ManageNavPages.Register;
    // We gebruiken bewust geen expliciete Layout=... om de circular reference te voorkomen.
    // Hij pakt nu veilig de standaard hoofd-layout.
}

@if (User.IsInRole(CustomIdentityConstants.GeneralAdminRoleName))
{
    <div>
        <h2 class="mb-2">Manage your account</h2>
        <h4 class="text-muted mb-4">Change your account settings</h4>
        <hr/>

        <div class="row">
            <div class="col-md-3">
                <partial name="/Areas/Identity/Pages/Account/Manage/_ManageNav.cshtml"/>
            </div>

            <div class="col-md-9">
                <h4 class="mb-3">Profile</h4>
                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @Model.StatusMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true"
                               placeholder="name@example.com"/>
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Name" class="form-control"/>
                        <label asp-for="Input.Name">Naam</label>
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <select asp-for="Input.SubPlatformId" asp-items="Model.SubPlatforms" class="form-select">
                            <option value="">Kies een  subplatform</option>
                        </select>
                        <label asp-for="Input.SubPlatformId">Subplatform</label>
                        <span asp-validation-for="Input.SubPlatformId" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password"
                               aria-required="true" placeholder="password"/>
                        <label asp-for="Input.Password">Wachtwoord</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password"
                               aria-required="true" placeholder="password"/>
                        <label asp-for="Input.ConfirmPassword">Bevestig Wachtwoord</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Save</button>
                </form>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial"/>
    }
}
else
{
    <p>Je hebt hier geen toegang tot.</p>
}