@page
@using IntegratieProject.UI.MVC
@using IntegratieProject.UI.MVC.Areas.Identity.Pages.Account.Manage
@using Microsoft.AspNetCore.Mvc.Rendering;
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    ViewData["ActivePage"] = ManageNavPages.Register;
}

@if (User.IsInRole(CustomIdentityConstants.GeneralAdminRoleName))
{
    <div class="container d-flex justify-content-center my-4 my-md-5">
        
        <div style="width: 100%; max-width: 1000px;">
            
            <div class="page-header mb-4">
                <h2 class="page-title mb-1">Manage your account</h2>
                <h5 class="text-muted fw-normal">Change your account settings</h5>
                <hr />
            </div>

            <div class="row g-4">
                <div class="col-md-4 col-lg-3">
                    <partial name="/Areas/Identity/Pages/Account/Manage/_ManageNav.cshtml"/>
                </div>

                <div class="col-md-8 col-lg-9">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                            <h4 class="mb-0">Profile</h4>
                        </div>
                        
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(Model.StatusMessage))
                            {
                                <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
                                    @Model.StatusMessage
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }
                            
                            <div class="row">
                                <div class="col-lg-10">
                                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                                        <div class="form-floating mb-3">
                                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="naam@voorbeeld.be"/>
                                            <label asp-for="Input.Email">E-mailadres</label>
                                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                        </div>

                                        <div class="form-floating mb-3">
                                            <input asp-for="Input.Name" class="form-control" placeholder="Naam"/>
                                            <label asp-for="Input.Name">Naam</label>
                                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                                        </div>

                                        <div class="form-floating mb-3">
                                            <select asp-for="Input.SubPlatformId" asp-items="Model.SubPlatforms" class="form-select">
                                                <option value="">Kies een subplatform</option>
                                            </select>
                                            <label asp-for="Input.SubPlatformId">Subplatform</label>
                                            <span asp-validation-for="Input.SubPlatformId" class="text-danger small"></span>
                                        </div>

                                        <div class="form-floating mb-3">
                                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Wachtwoord"/>
                                            <label asp-for="Input.Password">Wachtwoord</label>
                                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                        </div>

                                        <div class="form-floating mb-4">
                                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Wachtwoord bevestigen"/>
                                            <label asp-for="Input.ConfirmPassword">Bevestig Wachtwoord</label>
                                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                        </div>

                                        <button id="registerSubmit" type="submit" class="btn btn-primary w-100">Save</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial"/>
    }
}
else
{
    <div class="container my-5 text-center">
        <div class="alert alert-danger shadow-sm d-inline-block">Je hebt hier geen toegang toe.</div>
    </div>
}