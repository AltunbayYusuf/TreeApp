@using IntegratieProject.BL.interfaces
@using IntegratieProject.DAL.Identity
@using IntegratieProject.UI.MVC
@using Microsoft.AspNetCore.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IProjectManager PojectManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
      
        @if (User.IsInRole(CustomIdentityConstants.GeneralAdminRoleName))
        {
            <li class="nav-item">
                <a class="nav-link" id="register" asp-area="Identity"
                   asp-page="/Account/Register">Register</a>
            </li>
        }

        <li class="nav-item">
            @{
                var currentSubplatform = Context.Items["subplatform"]?.ToString() ?? "";
                var logoutProjectId = "";

                if (!string.IsNullOrWhiteSpace(currentSubplatform))
                {
                    var firstProject = PojectManager.GetFirstProjectBySubPlatform(currentSubplatform);

                    if (firstProject != null)
                    {
                        logoutProjectId = firstProject.Id.ToString();
                    }
                }
            }

            <form class="form-inline"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@($"/{currentSubplatform}/Project/{logoutProjectId}")"
                  method="post">
                <button type="submit" class="nav-link btn btn-link">Uitloggen</button>
            </form>
        </li>
        <li class="nav-item">
            <a id="manage" class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index"
               title="Beheer account">👤 @UserManager.GetUserName(User)</a>
        </li>
    }
    else
    {
        <a class="nav-link"
           id="login"
           asp-area="Identity"
           asp-page="/Account/Login"
           asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
            Login
        </a>
    }

</ul>
