@{
    var currentProjectId = Context.Request.Query["projectId"].ToString();

    if (string.IsNullOrWhiteSpace(currentProjectId) && ViewContext.RouteData.Values["projectId"] != null)
    {
        currentProjectId = ViewContext.RouteData.Values["projectId"]!.ToString();
    }

    if (string.IsNullOrWhiteSpace(currentProjectId) && ViewContext.RouteData.Values["id"] != null)
    {
        currentProjectId = ViewContext.RouteData.Values["id"]!.ToString();
    }

    if (string.IsNullOrWhiteSpace(currentProjectId))
    {
        currentProjectId = "1";
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Echo</title>
    @if (Context.RequestServices.GetRequiredService<IWebHostEnvironment>().IsDevelopment())
    {
        <link rel="stylesheet" vite-href="~/main.scss" asp-append-version="true" />
        <script type="module" vite-src="~/main.ts"></script>
    }
    else
    {
        <link rel="stylesheet" asp-href-include="~/dist/main*.css" />
        <script type="module" src="~/dist/main.js"></script>
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Echo</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav">
                    @* <li class="nav-item"> *@
                    @*     <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a> *@
                    @* </li> *@
                    <li class="nav-item">
                        <a class="nav-link text-dark"
                           asp-area=""
                           asp-controller="Project"
                           asp-action="Index"
                           asp-route-id="@currentProjectId">
                            Project
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark"
                           asp-area=""
                           asp-controller="Idea"
                           asp-action="Index"
                           asp-route-projectId="@currentProjectId">
                            Ideeën
                        </a>
                    </li>

                   

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - UI-MVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>