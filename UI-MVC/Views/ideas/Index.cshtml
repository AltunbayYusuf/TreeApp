@model IntergratieProject.Models.IdeasOverviewViewModel

@{
    ViewData["Title"] = "Ideeën";
}

<h1>Ideeën</h1>

<div class="mb-4 d-flex gap-3 align-items-end flex-wrap">
    <form method="get" asp-controller="Ideas" asp-action="Index">
        <label for="topicId" class="form-label">Filter op topic</label>
        <select id="topicId" name="topicId" class="form-select" onchange="this.form.submit()">
            <option value="">Alle topics</option>

            @foreach (var topic in Model.Topics)
            {
                if (Model.SelectedTopicId == topic.Id)
                {
                    <option value="@topic.Id" selected>@topic.Theme</option>
                }
                else
                {
                    <option value="@topic.Id">@topic.Theme</option>
                }
            }
        </select>
    </form>

    <div>
        <a asp-controller="Ideas" asp-action="Create" class="btn btn-primary">
            Ik heb een idee!
        </a>
    </div>
</div>

@if (!Model.Ideas.Any())
{
    <div class="alert alert-info">
        Geen ideeën gevonden.
    </div>
}
else
{
    <div class="list-group">
        @foreach (var idea in Model.Ideas)
        {
            <div class="list-group-item mb-3">
                <h5 class="mb-1">@idea.Title</h5>
                <p class="mb-2">@idea.Text</p>

                @if (idea.Topic != null)
                {
                    <small class="text-muted d-block mb-2">Topic: @idea.Topic.Theme</small>
                }

                <small class="text-muted d-block mb-2">Moderatie: @idea.ModerationStatus</small>

                @if (idea.Reactions != null && idea.Reactions.Any())
                {
                    <div class="mt-3">
                        <strong>Reacties</strong>
                        <ul class="mt-2 mb-0">
                            @foreach (var reaction in idea.Reactions)
                            {
                                <li>
                                    @if (!string.IsNullOrWhiteSpace(reaction.Emoji))
                                    {
                                        <span>@reaction.Emoji </span>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(reaction.Text))
                                    {
                                        <span>@reaction.Text</span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
                else
                {
                    <div class="mt-3 text-muted">
                        <small>Nog geen reacties.</small>
                    </div>
                }

                <form action="@Url.Action("Add", "Reaction")" method="post" class="mt-3">
                    <input type="hidden" name="ideaId" value="@idea.Id" />
                    <input type="hidden" name="emoji" id="emoji-@idea.Id" value="" />

                    <div class="mb-2">
                        <textarea name="text" class="form-control" rows="3" placeholder="Schrijf een reactie" required></textarea>
                    </div>

                    <div class="reaction-error text-danger mt-2" id="reaction-error-@idea.Id" style="display:none;">
                        Je reactie is leeg.
                    </div>

                    <button type="submit" class="btn btn-primary">Verzenden</button>
                    <button type="button" class="reaction-emoji-btn" data-idea-id="@idea.Id" data-emoji="👍">👍</button>
                    <button type="button" class="reaction-emoji-btn" data-idea-id="@idea.Id" data-emoji="❤️">❤️</button>
                </form>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll(".reaction-emoji-btn").forEach(button => {
            button.addEventListener("click", function () {
                const ideaId = this.dataset.ideaId;
                const emoji = this.dataset.emoji;
                const hiddenInput = document.getElementById("emoji-" + ideaId);
                if (hiddenInput) {
                    hiddenInput.value = emoji;
                }
            });
        });
    </script>
}