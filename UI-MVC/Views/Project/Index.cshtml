@using IntegratieProject.BL.Domain.project
@model IntegratieProject.BL.Domain.project.Project

@{
    ViewData["Title"] = "Project";
}

<div class="container mt-4" style="max-width: 700px;" xmlns="http://www.w3.org/1999/html">

    <div class="d-flex justify-content-between align-items-center border rounded p-3 mb-4 home-topbar">
        <div>
            @if (!string.IsNullOrWhiteSpace(@Model.Logo?.Uri))
            {
                <img src="@Model.Logo.Uri" alt="Logo" class="home-logo" />
            }
            else
            {
                <div class="border px-4 py-2 text-muted">[LOGO]</div>
            }
        </div>
    </div>

    <div class="border rounded mb-4 bg-light text-center home-image-box">
        @if (!string.IsNullOrWhiteSpace(@Model.Photo?.Uri))
        {
            <img src="@Model.Photo.Uri" alt="Project afbeelding" class="img-fluid rounded" />
        }
        else
        {
            <span class="text-muted">[PROJECT IMAGE]</span>
        }
    </div>

    <div class="mb-3">
        <div class="border rounded px-3 py-2 bg-light fw-bold">
            Welkom bij de bevraging
        </div>
        <p class="mt-2 mb-0 text-muted">@Model.SubPlatform.CompanyName</p>
    </div>

    <div class="border rounded p-4 mb-3 home-card">
        <p class="mb-0">@Model.Introduction</p>
    </div>

    <div class="border rounded p-3 mb-3 home-card">
        ⏱️ Duurt ongeveer @Model.Duration minuten
    </div>

    <div class="border rounded p-3 mb-4 home-card">
        🔒 Anoniem & Vertrouwelijk
    </div>

    @if (Model.Type == ProjectType.Chat)
    {
        <a asp-controller="Survey"
           asp-action="Chat"
           asp-route-subplatform="@Model.SubPlatform.Slug"
           asp-route-projectId="@Model.Id"
           class="btn btn-dark home-start-btn">
            Start bevraging
        </a>
    }
    else
    {
        <a asp-controller="Survey"
           asp-action="Index"
           asp-route-subplatform="@Model.SubPlatform.Slug"
           asp-route-projectId="@Model.Id"
           class="btn btn-dark home-start-btn">
            Start bevraging
        </a>
    }

    <div class="mt-4">
        <div class="border rounded p-3 text-muted"><a asp-controller="Home" asp-action="Privacy">→ Privacy policy </a> </div>
    </div>
</div>
