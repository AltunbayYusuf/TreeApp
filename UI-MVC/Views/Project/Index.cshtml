@using IntegratieProject.BL.Domain.project
@using IntegratieProject.UI.MVC.Models
@model IntegratieProject.BL.Domain.project.Project

@{
    ViewData["Title"] = "Project";
}

<div class="project-landing" style="font-family: @ProjectFontFamily.ToCssStack(Model.FontFamily); @ProjectColorTheme.ToCssVariables(Model.ColorTheme)">

    <div class="home-topbar mb-4 " >
        
        <div class="bg-light p-2 rounded" data-bs-theme="light">
            @if (!string.IsNullOrWhiteSpace(@Model.SubPlatform.Logo?.Uri))
            {
                <img src="@Model.SubPlatform.Logo.Uri" alt="Logo" class="home-logo"/>
            }
            else
            {
                <span class="fw-bold text-muted">[LOGO]</span>
            }
        </div>

    </div>

    <div class="project-image-box">
        @if (!string.IsNullOrWhiteSpace(Model.Photo?.Uri))
        {
            if (Model.IntroMediaType == ProjectIntroMediaType.Video)
            {
                <video controls playsinline preload="metadata" class="project-intro-video">
                    <source src="@Model.Photo.Uri" />
                    Je browser ondersteunt deze video niet.
                </video>
            }
            else
            {
                <img src="@Model.Photo.Uri" alt="Project afbeelding" />
            }
        }
        else
        {
            <span class="placeholder-icon">🖼️</span>
        }
    </div>

    <div class="project-info-card mb-3">
        <div class="project-welcome-label">Welkom bij de bevraging</div>
        <p class="project-company-name">@Model.SubPlatform.CompanyName</p>
    </div>

    <div class="project-info-card mb-3">
        <p class="mb-0" style="font-size:0.95rem; line-height:1.65;">@Model.Introduction</p>
    </div>

    <div class="project-meta-card">
        <span class="meta-icon">⏱️</span>
        <span>Duurt ongeveer <strong>@Model.Duration minuten</strong></span>
    </div>

    <div class="project-meta-card">
        <span class="meta-icon">🔒</span>
        <span><strong>Anoniem</strong> &amp; Vertrouwelijk</span>
    </div>

    @if (Model.Type == ProjectType.Chat)
    {
        <a asp-controller="Survey"
           asp-action="Chat"
           asp-route-projectId="@Model.Id"
           class="project-start-btn mt-3">
            Start bevraging →
        </a>
    }
    else
    {
        <a asp-controller="Survey"
           asp-action="Index"
           asp-route-projectId="@Model.Id"
           class="project-start-btn mt-3">
            Start bevraging →
        </a>
    }

    <a asp-controller="Home"
       asp-action="Privacy"
       asp-route-projectId="@Model.Id"
       class="project-privacy-link">
        → Privacybeleid
    </a>
</div>