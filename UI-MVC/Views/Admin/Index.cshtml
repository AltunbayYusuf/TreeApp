@model IntegratieProject.BL.Domain.users.GeneralAdmin

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<h1>Admin Dashboard</h1>
@Html.AntiForgeryToken()
<div id="overviewSection" style="margin-top:20px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Deelplatformen (@Model.Platform.SubPlatforms.Count())</h2>
        <button id="newSubplatform" class="btn btn-primary" type="button">
            Nieuwe deelplatform
        </button>
    </div>

    <!-- MODAL 1: Aanmaken Subplatform -->
    <div class="modal fade" id="createSubplatformModal" tabindex="-1" aria-labelledby="createSubplatformLabel"
         aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createSubplatformLabel">Nieuw Deelplatform Aanmaken</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
                </div>
                <form id="createSubplatformForm" novalidate>
                    <div class="modal-body">
                        <p class="text-muted mb-4">Maak een nieuw deelplatform aan voor een klant.</p>

                        <div class="mb-3">
                            <label for="companyName" class="form-label">Naam van de klant *</label>
                            <input id="companyName" name="companyName" type="text" class="form-control"
                                   placeholder="Bijv. Stad Gent" maxlength="50" required/>
                            <div class="invalid-feedback">Vul een geldige naam in (max. 50 tekens).</div>
                        </div>

                        <div class="mb-3">
                            <label for="adminEmail" class="form-label">Mailadres beheersaccount *</label>
                            <input id="adminEmail" name="adminEmail" type="email" class="form-control"
                                   placeholder="admin@voorbeeld.be" required/>
                            <div class="invalid-feedback">Vul een geldig e‑mailadres in.</div>
                        </div>

                        <div class="form-text">Een wachtwoord wordt automatisch gegenereerd en zo dadelijk getoond.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuleren
                        </button>
                        <button id="submitCreateSubplatform" type="submit" class="btn btn-primary">Aanmaken</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="successModal" tabindex="-1" aria-labelledby="successModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-success">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="successModalLabel">Subplatform Succesvol Aangemaakt</h5>
                </div>
                <div class="modal-body text-center">
                    <p class="mb-3">Het subplatform is aangemaakt. Het wachtwoord voor het beheersaccount <br /> <strong id="successEmail"></strong> is:</p>
                    
                    <div class="alert alert-secondary fs-4 fw-bold user-select-all" id="successPassword">
                        
                    </div>
                    
                    <p class="text-danger small mb-0">
                        <strong>Let op:</strong> Kopieer dit wachtwoord nu. Je krijgt dit hierna niet meer te zien!
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success w-100" id="reloadPageBtn">
                        klaar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @foreach (var subPlatform in @Model.Platform.SubPlatforms)
    {
        var subAdminsCount = Model.SubAdmins.Count(sa => sa.SubPlatform.Id == subPlatform.Id);

        <div class="card p-3 mb-3 ">
            <h3>@subPlatform.CompanyName</h3>
            <div class="row mt-2">
                <div class="col-md-4">
                    <p><strong>Aantal subadmins:</strong><br/>@subAdminsCount</p>
                </div>
                <div class="col-md-4">
                    <p><strong>Aantal projecten:</strong><br/>@(subPlatform.Projects?.Count() ?? 0)</p>
                </div>
                <div class="col-md-4">
                    <p><strong>Totaal deelnemers:</strong><br/>@(subPlatform.Projects?.Sum(p => p.SurveyResponses?.Count ?? 0) ?? 0)</p>
                </div>
            </div>
            <a class="text-center d-block mt-2 p-2 border rounded text-decoration-none text-bg-light"
               asp-action="Details"
               asp-controller="Platform"
               asp-route-id="@subPlatform.Id">
                Details bekijken →
            </a>
        </div>
    }
</div>