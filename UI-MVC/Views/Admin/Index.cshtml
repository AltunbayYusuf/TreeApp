@model IntegratieProject.UI.MVC.Models.Admin.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

@Html.AntiForgeryToken()

<section id="overviewSection" class="admin-dashboard-page">
    <div class="admin-dashboard-hero mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light mb-3">Platformbeheer</span>
            <h1 class="display-6 fw-bold mb-2">Admin Dashboard</h1>
            <p class="text-white-50 mb-0">Beheer deelplatformen, subadmins en projecten vanuit een overzichtelijke
                omgeving.</p>
        </div>
        <button id="newSubplatform" class="btn btn-light btn-lg fw-semibold shadow-sm" type="button">
            + Nieuw deelplatform
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="card admin-summary-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small fw-semibold text-uppercase mb-2">Deelplatformen</div>
                    <div class="h2 fw-bold mb-0">@Model.SubPlatformCount</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card admin-summary-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small fw-semibold text-uppercase mb-2">Subadmins</div>
                    <div class="h2 fw-bold mb-0">@Model.SubAdminCount</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card admin-summary-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small fw-semibold text-uppercase mb-2">Projecten</div>
                    <div class="h2 fw-bold mb-0">@Model.ProjectCount</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card admin-summary-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small fw-semibold text-uppercase mb-2">Deelnemers</div>
                    <div class="h2 fw-bold mb-0">@Model.ParticipantCount</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="h4 fw-bold mb-1">Deelplatformen</h2>
            <p class="text-muted mb-0">Bekijk snel de activiteit per klant.</p>
        </div>
        <span class="badge text-bg-primary rounded-pill px-3 py-2">@Model.SubPlatformCount totaal</span>
    </div>

    <div class="row g-3">
        @foreach (var subPlatform in Model.SubPlatforms)
        {
            <div class="col-12 col-lg-6 col-xxl-4">
                <div class="card admin-platform-card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
                            <div>
                                <div class="admin-platform-icon mb-3">@subPlatform.Initial</div>
                                <h3 class="h5 fw-bold mb-1">@subPlatform.CompanyName</h3>
                                <p class="text-muted mb-0 small">Deelplatform overzicht</p>
                            </div>
                            <span class="badge text-bg-light border">Actief</span>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col-4">
                                <div class="admin-mini-stat">
                                    <span>@subPlatform.SubAdminCount</span>
                                    <small>Subadmins</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="admin-mini-stat">
                                    <span>@subPlatform.ProjectCount</span>
                                    <small>Projecten</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="admin-mini-stat">
                                    <span>@subPlatform.ParticipantCount</span>
                                    <small>Deelnemers</small>
                                </div>
                            </div>
                        </div>

                        <a class="btn btn-outline-primary w-100 fw-semibold"
                           asp-action="Details"
                           asp-controller="Platform"
                           asp-route-id="@subPlatform.Id">
                            Details bekijken &rarr;
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="modal fade" id="createSubplatformModal" tabindex="-1" aria-labelledby="createSubplatformLabel"
         aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title" id="createSubplatformLabel">Nieuw deelplatform aanmaken</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
                </div>
                <form id="createSubplatformForm" novalidate>
                    <div class="modal-body">
                        <p class="text-muted mb-4">Maak een nieuw deelplatform aan voor een klant.</p>

                        <div class="mb-3">
                            <label for="companyName" class="form-label">Naam van de klant *</label>
                            <input id="companyName" name="companyName" type="text" class="form-control"
                                   placeholder="Bijv. Stad Gent" maxlength="50" required/>
                            <div class="invalid-feedback">Vul een geldige naam in (max. 50 tekens).</div>
                        </div>

                        <div class="mb-3">
                            <label for="adminEmail" class="form-label">Mailadres beheersaccount *</label>
                            <input id="adminEmail" name="adminEmail" type="email" class="form-control"
                                   placeholder="admin@voorbeeld.be" required/>
                            <div class="invalid-feedback">Vul een geldig e-mailadres in.</div>
                        </div>

                        <div class="form-text">Een wachtwoord wordt automatisch gegenereerd en zo dadelijk getoond.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuleren
                        </button>
                        <button id="submitCreateSubplatform" type="submit" class="btn btn-primary">Aanmaken</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="successModal" tabindex="-1" aria-labelledby="successModalLabel" aria-hidden="true"
         data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-success">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="successModalLabel">Subplatform succesvol aangemaakt</h5>
                </div>
                <div class="modal-body text-center">
                    <p class="mb-3">Het subplatform is aangemaakt. Het wachtwoord voor het beheersaccount <br/> <strong
                            id="successEmail"></strong> is:</p>

                    <div class="alert alert-secondary fs-4 fw-bold user-select-all" id="successPassword"></div>

                    <p class="text-danger small mb-0">
                        <strong>Let op:</strong> Kopieer dit wachtwoord nu. Je krijgt dit hierna niet meer te zien!
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success w-100" id="reloadPageBtn">
                        Klaar
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
