@model IntegratieProject.BL.Domain.users.GeneralAdmin

@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1>Admin Dashboard</h1>
<p>Welkom beheerder.</p>

<button id="overviewBtn" class="btn btn-primary">
    Overzicht
</button>

<div id="overviewSection" style="display:none; margin-top:20px;">
    <h2>Deelplatform Overzicht</h2>

    @foreach (var platform in @Model.Platform.SubPlatforms)
    {
        var subAdminsCount = Model.SubAdmins
            .Count(sa => sa.SubPlatform.Id == platform.Id);

        var projectCount = platform.Projects?.Count() ?? 0;

        <div class="card p-3 mb-3">
            <h3>@platform.CompanyName</h3>

            <p>
                <strong>Aantal subadmins:</strong>
                @subAdminsCount
            </p>

            <p>
                <strong>Aantal projecten:</strong>
                @projectCount
            </p>
        </div>
    }
</div>

