@model IntegratieProject.UI.MVC.Models.Admin.AdminStatsOverviewViewModel

@{
    ViewBag.Title = "Deelplatform beheerders";
    Layout = "_AdminLayout";
}

<div class="min-h-screen bg-slate-50">
    <div class="mx-auto max-w-7xl px-6 py-8">

        <div class="mb-8">
            <h1 class="text-3xl font-bold tracking-tight text-slate-900">
                Deelplatform beheerders
            </h1>
            <p class="mt-2 text-sm text-slate-500">
                Overzicht van alle beheerders per deelplatform.
            </p>
        </div>

        <div class="mb-8 grid max-w-3xl grid-cols-1 gap-4 md:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <p class="text-sm font-medium text-slate-500">
                    Totaal deelplatformen
                </p>
                <p class="mt-3 text-3xl font-bold text-slate-900">
                    @Model.TotalPlatforms
                </p>
            </div>

            <div class="rounded-2xl border border-blue-200 bg-gradient-to-br from-blue-50 to-white p-6 shadow-sm">
                <p class="text-sm font-medium text-blue-600">
                    Totaal beheerders
                </p>
                <p class="mt-3 text-3xl font-bold text-blue-700">
                    @Model.TotalAdmins
                </p>
            </div>
        </div>

        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-6 py-5">
                <h2 class="text-lg font-semibold text-slate-900">
                    Overzicht per deelplatform
                </h2>
                <p class="mt-1 text-sm text-slate-500">
                    Lijst van deelplatformen en hun gekoppelde beheerders.
                </p>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">
                                Organisatie
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">
                                Subdomein
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">
                                Aantal beheerders
                            </th>
                            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">
                                Beheerders
                            </th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-slate-100 bg-white">
                        @if (Model.Platforms != null && Model.Platforms.Any())
                        {
                            @foreach (var platform in Model.Platforms)
                            {
                                <tr class="align-top transition hover:bg-slate-50">
                                    <td class="px-6 py-5">
                                        <div class="font-semibold text-slate-900">
                                            @platform.SubPlatformName
                                        </div>
                                    </td>

                                    <td class="px-6 py-5">
                                        <span class="inline-flex rounded-lg border border-slate-200 bg-slate-50 px-3 py-1 text-sm font-medium text-slate-700">
                                            @platform.SubPlatformSlug
                                        </span>
                                    </td>

                                    <td class="px-6 py-5">
                                        <span class="inline-flex min-w-[44px] items-center justify-center rounded-full bg-blue-100 px-3 py-1 text-sm font-semibold text-blue-700">
                                            @(platform.Admins?.Count ?? 0)
                                        </span>
                                    </td>

                                    <td class="px-6 py-5">
                                        @if (platform.Admins != null && platform.Admins.Any())
                                        {
                                            <div class="flex flex-wrap gap-2">
                                                @foreach (var admin in platform.Admins)
                                                {
                                                    <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                                                        <div class="text-sm font-semibold text-slate-800">
                                                            @admin.FullName
                                                        </div>
                                                        <div class="text-xs text-slate-500">
                                                            @admin.Email
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-sm italic text-slate-400">
                                                Geen beheerders gekoppeld
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-10 text-center text-sm text-slate-500">
                                    Geen deelplatformen gevonden.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>