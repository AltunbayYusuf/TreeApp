@model IntegratieProject.UI.MVC.Models.Admin.AdminStatsOverviewViewModel

@{
    ViewBag.Title = "Deelplatform beheerders";
    Layout = "_AdminLayout";
}

<div class="min-vh-100 py-5">
    <div class="container-xl">

        <div class="mb-5">
            <h1 class="display-6 fw-bold">
                Deelplatform beheerders
            </h1>
            <p class="mt-2 text-body-secondary">
                Overzicht van alle beheerders per deelplatform.
            </p>
        </div>

        <div class="row g-4 mb-5" style="max-width: 900px;">
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border rounded-4">
                    <div class="card-body p-4">
                        <p class="card-subtitle mb-2 text-body-secondary fw-medium">
                            Totaal deelplatformen
                        </p>
                        <p class="card-text fs-1 fw-bold mb-0">
                            @Model.TotalPlatforms
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100 shadow-sm border border-primary-subtle bg-primary-subtle text-primary-emphasis rounded-4">
                    <div class="card-body p-4">
                        <p class="card-subtitle mb-2 fw-medium">
                            Totaal beheerders
                        </p>
                        <p class="card-text fs-1 fw-bold mb-0">
                            @Model.TotalAdmins
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border rounded-4 overflow-hidden">
            <div class="card-header bg-transparent border-bottom p-4">
                <h2 class="h5 mb-1 fw-semibold">
                    Overzicht per deelplatform
                </h2>
                <p class="mb-0 small text-body-secondary">
                    Lijst van deelplatformen en hun gekoppelde beheerders.
                </p>
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th scope="col" class="px-4 py-3 text-uppercase text-body-secondary small fw-semibold border-bottom">
                                Organisatie
                            </th>
                            <th scope="col" class="px-4 py-3 text-uppercase text-body-secondary small fw-semibold border-bottom">
                                Subdomein
                            </th>
                            <th scope="col" class="px-4 py-3 text-uppercase text-body-secondary small fw-semibold border-bottom">
                                Aantal beheerders
                            </th>
                            <th scope="col" class="px-4 py-3 text-uppercase text-body-secondary small fw-semibold border-bottom">
                                Beheerders
                            </th>
                        </tr>
                    </thead>

                    <tbody class="table-group-divider">
                        @if (Model.Platforms != null && Model.Platforms.Any())
                        {
                            @foreach (var platform in Model.Platforms)
                            {
                                <tr>
                                    <td class="px-4 py-3">
                                        <div class="fw-semibold">
                                            @platform.SubPlatformName
                                        </div>
                                    </td>

                                    <td class="px-4 py-3">
                                        <span class="badge border bg-body-secondary text-body-secondary p-2 rounded-3">
                                            @platform.SubPlatformSlug
                                        </span>
                                    </td>

                                    <td class="px-4 py-3">
                                        <span class="badge rounded-pill text-bg-primary px-3 py-2">
                                            @(platform.Admins?.Count ?? 0)
                                        </span>
                                    </td>

                                    <td class="px-4 py-3">
                                        @if (platform.Admins != null && platform.Admins.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (var admin in platform.Admins)
                                                {
                                                    <div class="border rounded-3 px-3 py-2">
                                                        <div class="small fw-semibold">
                                                            @admin.FullName
                                                        </div>
                                                        <div class="small text-body-secondary" style="font-size: 0.75rem;">
                                                            @admin.Email
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="small fst-italic text-body-secondary">
                                                Geen beheerders gekoppeld
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="px-4 py-5 text-center small text-body-secondary">
                                    Geen deelplatformen gevonden.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>