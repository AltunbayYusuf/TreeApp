@model IntegratieProject.UI.MVC.Models.IdeasOverviewViewModel
@{
    ViewData["Title"] = "Ideeën";
    var reactionEmojis = (Model.Project.ReactionEmojiGroup ?? "👍,❤️")
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Where(emoji => !string.IsNullOrWhiteSpace(emoji))
        .Distinct()
        .ToList();

    if (!reactionEmojis.Any())
    {
        reactionEmojis = new List<string> { "👍", "❤️" };
    }
}

<div class="max-w-3xl mx-auto px-4 py-6">

    <h1 class="text-3xl font-bold mb-6">Ideeën</h1>

    <div class="mb-4 flex gap-3 items-end flex-wrap">
        <form method="get" asp-controller="Idea" asp-action="Index">
            <input type="hidden" name="subplatform" value="@Model.Project.SubPlatform.Slug" />
            <input type="hidden" name="projectId" value="@Model.Project.Id" />
            <label for="topicId" class="form-label">Filter op topic</label>
            <select id="topicId" name="topicId" class="form-select" onchange="this.form.submit()">
                <option value="">Alle topics</option>

                @foreach (var topic in Model.Topics)
                {
                    if (Model.SelectedTopicId == topic.Id)
                    {
                        <option value="@topic.Id" selected>@topic.Theme</option>
                    }
                    else
                    {
                        <option value="@topic.Id">@topic.Theme</option>
                    }
                }
            </select>
        </form>

        <div>
            <a asp-controller="Idea"
               asp-action="Create"
               asp-route-subplatform="@Model.Project.SubPlatform.Slug"
               asp-route-projectId="@Model.Project.Id"
               class="btn btn-primary">
                Ik heb een idee!
            </a>
            
        </div>

        <div class="ms-sm-auto d-flex align-items-center gap-2">
            <label class="fw-semibold mb-0 text-nowrap">Ideeën:</label>
            <div class="btn-group btn-group-sm" role="group" aria-label="Idee filter">
                <button type="button" class="btn btn-dark" data-idea-filter="all">
                    Alle ideeën
                </button>
                <button type="button" class="btn btn-outline-secondary" data-idea-filter="mine">
                    Mijn ideeën
                </button>
            </div>
        </div>
    </div>

    @if (!Model.Ideas.Any())
    {
        <div class="alert alert-info">
            Geen ideeën gevonden.
        </div>
    }
    else
    {
        <div class="space-y-4">

            @foreach (var idea in Model.Ideas)
            {
                var isOwnIdea = Model.CurrentUserId.HasValue && idea.UserId == Model.CurrentUserId.Value;
                var textReactions = idea.Reactions?.Where(r => !string.IsNullOrWhiteSpace(r.Text)).ToList() ??
                                    new List<IntegratieProject.BL.Domain.ideas.Reaction>();
                <div class="list-group-item mb-3 idea-item shadow rounded p-4 @(isOwnIdea ? "idea-item-own" : "bg-white")"
                     data-own-idea="@(isOwnIdea.ToString().ToLowerInvariant())"
                     style="display:none;">

                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                        <h5 class="mb-0">@idea.Title</h5>
                        @if (isOwnIdea)
                        {
                            <span class="idea-item-own-badge">Door jou</span>
                        }
                    </div>
                    <p class="mb-2">@idea.Text</p>
                    
                    @if (idea.Image != null && !string.IsNullOrWhiteSpace(idea.Image.Uri))
                    {
                        <div class="my-3">
                            <img src="@idea.Image.Uri"
                                 alt="Afbeelding bij idee"
                                 class="img-fluid rounded border"
                                 style="max-height: 350px; object-fit: cover;" />
                        </div>
                    }
                    @if (idea.Topic != null)
                    {
                        <small class="text-muted d-block mb-2">
                            Topic: @idea.Topic.Theme
                        </small>
                    }

                    <div class="mt-3 reactions-wrapper">
                        <strong>Reacties</strong>

                        @if (textReactions.Any())
                        {
                            <ul id="reactions-list-@idea.Id" class="mt-2 mb-0 reactions-list">
                                @foreach (var reaction in textReactions)
                                {
                                    <li>
                                        @if (!string.IsNullOrWhiteSpace(reaction.Emoji))
                                        {
                                            <span>@reaction.Emoji </span>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(reaction.Text))
                                        {
                                            <span>@reaction.Text</span>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <ul id="reactions-list-@idea.Id" class="mt-2 mb-0 reactions-list" style="display:none;"></ul>

                            <small id="no-reactions-@idea.Id" class="text-muted no-reactions-message">
                                Nog geen reacties.
                            </small>
                        }
                    </div>

                    <form class="mt-3 reaction-form" data-idea-id="@idea.Id">

                        <input type="hidden" name="ideaId" value="@idea.Id" />
                        <input type="hidden" name="emoji" id="emoji-@idea.Id" value="" />

                        <div class="mb-2">
                            <textarea
                                name="text"
                                class="form-control"
                                rows="3"
                                placeholder="Schrijf een reactie"></textarea>
                        </div>

                        <div
                            class="reaction-result mt-2"
                            id="reaction-result-@idea.Id"
                            style="display:none;"></div>

                        <div
                            class="d-flex gap-2 flex-wrap mt-2">

                            <button type="submit" class="btn btn-primary">
                                Verzenden
                            </button>

                            @foreach (var emoji in reactionEmojis)
                            {
                                var isSelected = Model.CurrentUserId.HasValue &&
                                                 idea.Reactions?.Any(r => r.UserId == Model.CurrentUserId && r.Text == null && r.Emoji == emoji) == true;
                                var emojiCount = idea.Reactions?.Count(r => r.Text == null && r.Emoji == emoji) ?? 0;
                                <button
                                    type="button"
                                    class="reaction-emoji-btn btn @(isSelected ? "btn-primary selected" : "btn-outline-secondary")"
                                    data-idea-id="@idea.Id"
                                    data-emoji="@emoji">
                                    @emoji
                                    <span class="reaction-count" data-count-for="@idea.Id-@emoji">@emojiCount</span>
                                </button>
                            }

                        </div>

                    </form>

                </div>
            }

        </div>
    }

    <div class="mt-3">
        <button id="show-more-btn" class="btn btn-outline-primary">
            Toon meer
        </button>
    </div>

</div>