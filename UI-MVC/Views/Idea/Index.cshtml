@model IntegratieProject.UI.MVC.Models.IdeasOverviewViewModel

@{
    ViewData["Title"] = "Ideeën";

    var reactionEmojis = (Model.Project.ReactionEmojiGroup ?? "👍,❤️")
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Where(emoji => !string.IsNullOrWhiteSpace(emoji))
        .Distinct()
        .ToList();

    if (!reactionEmojis.Any())
    {
        reactionEmojis = new List<string> { "👍", "❤️" };
    }
}

@using IntegratieProject.UI.MVC.Models

<div class="ideas-page" style="font-family: @ProjectFontFamily.ToCssStack(Model.Project.FontFamily);">

    <div class="ideas-page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h1>Ideeën</h1>
            <p class="text-muted mb-0">Bekijk en reageer op ingediende ideeën</p>
        </div>

        <a asp-controller="Idea"
           asp-action="Create"
           asp-route-projectId="@Model.Project.Id"
           class="btn btn-primary">
            + Ik heb een idee!
        </a>
    </div>
    <div id="ideasPageData" data-project-id="@Model.Project.Id"></div>

    <div class="ideas-filter-bar mt-3 d-flex align-items-end justify-content-between flex-wrap gap-3">
        <form method="get"
              asp-controller="Idea"
              asp-action="Index"
              class="d-flex align-items-end gap-2 flex-wrap">

            <input type="hidden" name="projectId" value="@Model.Project.Id" />

            <div>
                <label for="topicId" class="form-label mb-1">Filter op topic</label>
                <select id="topicId"
                        name="topicId"
                        class="form-select form-select-sm"
                        style="min-width:180px;"
                        onchange="this.form.submit()">
                    <option value="">Alle topics</option>

                    @foreach (var topic in Model.Topics)
                    {
                        if (Model.SelectedTopicId == topic.Id)
                        {
                            <option value="@topic.Id" selected>@topic.Theme</option>
                        }
                        else
                        {
                            <option value="@topic.Id">@topic.Theme</option>
                        }
                    }
                </select>
            </div>
        </form>

        <div class="d-flex align-items-center gap-2">
            <label class="fw-semibold mb-0 text-nowrap">Ideeën:</label>
            <div class="btn-group btn-group-sm" role="group" aria-label="Idee filter">
                <button type="button" class="btn btn-dark" data-idea-filter="all">
                    Alle ideeën
                </button>
                <button type="button" class="btn btn-outline-secondary" data-idea-filter="mine">
                    Mijn ideeën
                </button>
                <button type="button" class="btn btn-outline-secondary" data-idea-filter="similar">
                    Gelijkaardig
                </button>
                <button type="button" class="btn btn-outline-secondary" data-idea-filter="different">
                    Verschillend
                </button>
                <button type="button" class="btn btn-outline-secondary" data-idea-filter="broad">
                    Breed
                </button>
            </div>
        </div>
    </div>

    @if (!Model.Ideas.Any())
    {
        <div class="alert alert-info mt-3">
            <strong>Geen ideeën gevonden.</strong> Wees de eerste die een idee deelt!
        </div>
    }
    else
    {
        <div class="mt-3">
            @foreach (var idea in Model.Ideas)
            {
                var isOwnIdea = Model.CurrentUserId.HasValue && idea.UserId == Model.CurrentUserId.Value;
                var textReactions = idea.Reactions?.Where(r => !string.IsNullOrWhiteSpace(r.Text)).ToList() ??
                                    new List<IntegratieProject.BL.Domain.ideas.Reaction>();

                <div class="idea-card idea-item @(isOwnIdea ? "idea-item-own" : "")"
                     data-idea-id="@idea.Id"
                     data-own-idea="@(isOwnIdea.ToString().ToLowerInvariant())"
                     style="display:none;">

                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                        <h5 class="idea-title mb-0">@idea.Title</h5>

                        @if (isOwnIdea)
                        {
                            <span class="idea-item-own-badge">Door jou</span>
                        }
                    </div>

                    <p class="idea-body">@idea.Text</p>

                    @if (idea.Image != null && !string.IsNullOrWhiteSpace(idea.Image.Uri))
                    {
                        <div class="my-3 text-center">
                            <img src="@idea.Image.Uri"
                                 alt="Afbeelding bij idee"
                                 class="img-fluid rounded border w-75 w-md-50" />
                        </div>
                    }

                    @if (idea.Topic != null)
                    {
                        <span class="idea-topic-pill">@idea.Topic.Theme</span>
                    }

                    <div class="reactions-wrapper">
                        <div class="reactions-label">Reacties</div>

                        @if (textReactions.Any())
                        {
                            <ul id="reactions-list-@idea.Id" class="reactions-list">
                                @foreach (var reaction in textReactions)
                                {
                                    var isOwnReaction = Model.CurrentUserId.HasValue && reaction.UserId == Model.CurrentUserId.Value;

                                    <li>
                                        <span class="reaction-text">
                                            @if (!string.IsNullOrWhiteSpace(reaction.Emoji))
                                            {
                                                <span>@reaction.Emoji</span>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(reaction.Text))
                                            {
                                                <span>@reaction.Text</span>
                                            }
                                        </span>

                                        @if (isOwnReaction)
                                        {
                                            <span class="reaction-own-badge">Door jou</span>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <ul id="reactions-list-@idea.Id" class="reactions-list" style="display:none;"></ul>

                            <small id="no-reactions-@idea.Id" class="no-reactions-message">
                                Nog geen reacties.
                            </small>
                        }
                    </div>

                        <form class="mt-3 reaction-form" data-idea-id="@idea.Id">
                            <input type="hidden" name="ideaId" value="@idea.Id" />
                            <input type="hidden" name="emoji" id="emoji-@idea.Id" value="" />

                            <div class="mb-2">
                                <textarea name="text"
                                          class="form-control"
                                          rows="2"
                                          placeholder="Schrijf een reactie..."></textarea>
                            </div>

                            <div class="reaction-result mt-2"
                                 id="reaction-result-@idea.Id"
                                 style="display:none;"></div>

                            <div class="d-flex gap-2 flex-wrap mt-2">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    Verzenden
                                </button>

                                @foreach (var emoji in reactionEmojis)
                                {
                                    var isSelected = Model.CurrentUserId.HasValue &&
                                                     idea.Reactions?.Any(r =>
                                                         r.UserId == Model.CurrentUserId &&
                                                         r.Text == null &&
                                                         r.Emoji == emoji) == true;

                                    var emojiCount = idea.Reactions?.Count(r =>
                                        r.Text == null &&
                                        r.Emoji == emoji) ?? 0;

                                    <button type="button"
                                            class="reaction-emoji-btn btn btn-sm @(isSelected ? "btn-primary selected" : "btn-outline-secondary")"
                                            data-idea-id="@idea.Id"
                                            data-emoji="@emoji">
                                        @emoji
                                        <span class="reaction-count"
                                              data-count-for="@idea.Id-@emoji">@emojiCount</span>
                                    </button>
                                }
                            </div>
                        </form>
                    </div>

            }
        </div>
    }

    <div class="mt-4">
        <button id="show-more-btn" class="btn btn-outline-primary">
            Toon meer ideeën
        </button>
    </div>

</div>
