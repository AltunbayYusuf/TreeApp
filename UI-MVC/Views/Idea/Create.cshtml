@model IntegratieProject.UI.MVC.Models.IdeasOverviewViewModel

@{
    ViewData["Title"] = "Deel jouw idee";
}

<h1 class="text-center">Deel jouw idee</h1>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card mb-4">
            <div class="card-body">
                <p class="text-muted">
                    We willen graag jouw ideeën horen om het mentaal welzijn te verbeteren. Deel je suggestie hieronder.
                </p>

                <div class="mb-3">
                    <label for="idea-title" class="form-label">Titel van je idee</label>
                    <input id="idea-title" class="form-control" type="text"
                           placeholder="Geef je idee een korte titel..." maxlength="100"/>
                </div>

                <div class="mb-3">
                    <label for="idea-topic" class="form-label">Kies een topic</label>
                    <select id="idea-topic" class="form-select">
                        <option value="0">Waar gaat je idee over?</option>
                        @foreach (var topic in Model.Topics)
                        {
                            <option value="@topic.Id">@topic.Theme</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label for="idea-text" class="form-label">Beschrijf je idee</label>
                    <textarea id="idea-text" class="form-control" rows="6" maxlength="1000"
                              placeholder="Beschrijf hier je idee zo gedetailleerd mogelijk. Wat wil je verbeteren? Hoe zou het werken? Wie zou het helpen?"></textarea>
                    <div class="mt-2">
                        <button type="button"
                                id="ai-improve-create-btn"
                                class="btn btn-outline-secondary btn-sm">
                            ✨ Herschrijf met AI
                        </button>
                    </div>

                    <div id="ai-improve-result" class="mt-3" style="display:none;">
                        <div class="alert alert-success mb-0">
                            <strong>AI alternatief:</strong>
                            <p id="ai-improve-text" class="mt-2 mb-2" style="white-space: pre-line;"></p>

                            <button type="button"
                                    id="use-ai-improvement-btn"
                                    class="btn btn-success btn-sm">
                                Gebruik alternatief
                            </button>
                        </div>
                    </div>
                    <div id="followUpQuestionsBlock" class="card shadow-sm border-0 mt-4 d-none">
                        <div class="card-body">
                            <h5 class="card-title mb-2">AI wil je idee beter begrijpen</h5>
                            <p class="text-muted mb-3">
                                Beantwoord deze vragen als je je idee duidelijker wil maken. Dit is optioneel.
                            </p>

                            <div id="followUpQuestionsContainer" class="d-flex flex-column gap-3"></div>

                            <div class="d-flex gap-2 mt-4">
                                <button type="button" id="submitWithFollowUpsBtn" class="btn btn-primary">
                                    Idee indienen
                                </button>

                                <button type="button" id="skipFollowUpsBtn" class="btn btn-outline-secondary">
                                    Overslaan
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="idea-image" class="form-label">Afbeelding toevoegen</label>
                    <input id="idea-image"
                           class="form-control"
                           type="file"
                           accept="image/png,image/jpeg,image/jpg,image/webp" />

                    <small class="text-muted">
                        Je kan een afbeelding toevoegen aan je idee.
                    </small>

                    <div class="mt-3" id="idea-image-preview-wrapper" style="display:none;">
                        <img id="idea-image-preview"
                             src=""
                             alt="Voorbeeld afbeelding"
                             class="img-fluid rounded border"
                             style="max-height: 250px; object-fit: cover;" />
                    </div>
                </div>

                <input type="hidden"
                       id="idea-subplatform-slug"
                       value="@Model.Project.SubPlatform.Slug" />
                
                <input type="hidden"
                       id="followUpAnswers"
                       name="FollowUpAnswers"
                       value="" />

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="idea-contact-opt-in"/>
                    <label class="form-check-label" for="idea-contact-opt-in">
                        Ik wil gecontacteerd kunnen worden over dit idee
                    </label>
                </div>

                <div id="idea-contact-email-wrapper" class="mb-3" style="display:none;">
                    <label for="idea-contact-email" class="form-label">Jouw e-mail</label>
                    <input id="idea-contact-email" class="form-control" type="email" placeholder="jouw@email.be"/>
                </div>

                <div id="idea-ai-message" class="mb-3" style="display:none;"></div>

                <div class="d-grid">
                    <button type="button" id="submit-idea-btn" class="btn btn-primary">
                        Verstuur idee
                    </button>
                </div>

                <div class="mt-3">
                    <a asp-controller="Idea"
                       asp-action="Index"
                       asp-route-subplatform="@Model.Project.SubPlatform.Slug"
                       asp-route-projectId="@Model.Project.Id"
                       class="btn btn-link ps-0">
                        ← Terug naar ideeën
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
