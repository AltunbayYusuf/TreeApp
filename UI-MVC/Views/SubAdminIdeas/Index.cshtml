@model IntegratieProject.UI.MVC.Models.SubAdminDashboardViewModel

<div class="container-fluid p-4 p-md-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="fs-2 fw-bold mb-1">Ideeen</h1>
            <p class="text-muted mb-0">Overzicht van alle ingediende ideeen</p>
        </div>
    </div>

    <span id="subplatformIdData" data-id="@Model.SubPlatformId" class="d-none"></span>

    <div class="border">

        <div class="p-3 border-bottom">

            <div class="d-flex flex-column flex-sm-row gap-2 align-items-sm-center mb-2">
                <label class="fw-semibold mb-0 text-nowrap">Project:</label>
                <select id="projectFilter" class="form-select form-select-sm w-auto">
                    <option value="">-- Alle projecten --</option>
                    @foreach (var p in Model.Projects)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>

                <span id="ideasCount" class="text-muted small"></span>

                <div class="ms-sm-auto d-flex align-items-center gap-2">
                    <label class="fw-semibold mb-0 text-nowrap">Datum:</label>
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn btn-dark" data-sort="newest">
                            Nieuwste eerst
                        </button>
                        <button type="button" class="btn btn-outline-secondary" data-sort="oldest">
                            Oudste eerst
                        </button>
                    </div>
                </div>
            </div>

            <div id="similarityFilterGroup" style="display:none"
                 class="d-flex align-items-center gap-2 flex-wrap">
                <label class="fw-semibold mb-0 text-nowrap text-muted">Vergelijking:</label>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-dark"
                            data-similarity="all" disabled>
                        Alle ideeen
                    </button>
                    <button type="button" class="btn btn-outline-secondary"
                            data-similarity="common" disabled>
                        Gemeenschappelijk
                    </button>
                    <button type="button" class="btn btn-outline-secondary"
                            data-similarity="unique" disabled>
                        Verschillend
                    </button>
                </div>
                <span class="badge bg-secondary ms-1">AI -- binnenkort</span>
            </div>

        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="p-3">Titel</th>
                        <th class="p-3">Inhoud</th>
                        <th class="p-3">Topic</th>
                        <th class="p-3">Project</th>
                        <th class="p-3">Status</th>
                        <th class="p-3">Email</th>
                        <th class="p-3">Reacties</th>
                    </tr>
                </thead>
                <tbody id="ideasTableBody">
                    <tr id="ideasLoadingRow">
                        <td colspan="7" class="text-center text-muted p-4">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            Laden...
                        </td>
                    </tr>
                    <tr id="ideasEmptyRow" style="display:none">
                        <td colspan="7" class="text-center text-muted p-4">
                            Geen ideeen gevonden.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>
