@model IntegratieProject.UI.MVC.Models.SubAdminDashboardViewModel

<div class="container-fluid p-4 p-md-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="fs-2 fw-bold mb-1">ideeën</h1>
            <p class="text-muted mb-0">Overzicht van alle ingediende ideeën</p>
        </div>
    </div>

    <span id="subplatformIdData" data-id="@Model.SubPlatformId" class="d-none"></span>

    <div class="border">

        <div class="p-3 border-bottom">

            <div class="d-flex flex-column flex-sm-row gap-2 align-items-sm-center mb-2">
                <label class="fw-semibold mb-0 text-nowrap">Project:</label>
                <select id="projectFilter" class="form-select form-select-sm w-auto">
                    <option value="">-- Alle projecten --</option>
                    @foreach (var p in Model.Projects)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>

                <span id="ideasCount" class="text-muted small"></span>

                <div class="ms-sm-auto d-flex align-items-center gap-2">
                    <label class="fw-semibold mb-0 text-nowrap">Datum:</label>
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn btn-dark" data-sort="newest">
                            Nieuwste eerst
                        </button>
                        <button type="button" class="btn btn-outline-secondary" data-sort="oldest">
                            Oudste eerst
                        </button>
                    </div>
                </div>
            </div>

            <div id="similarityFilterGroup" style="display:none"
                 class="d-flex align-items-center gap-2 flex-wrap">
                <label class="fw-semibold mb-0 text-nowrap text-muted">Vergelijking:</label>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-dark"
                            data-similarity="all" disabled>
                        Alle ideeën
                    </button>
                    <button type="button" class="btn btn-outline-secondary"
                            data-similarity="common" disabled>
                        Gemeenschappelijk
                    </button>
                    <button type="button" class="btn btn-outline-secondary"
                            data-similarity="unique" disabled>
                        Verschillend
                    </button>
                </div>
            </div>

        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="p-3">Titel</th>
                        <th class="p-3">Inhoud</th>
                        <th class="p-3">Topic</th>
                        <th class="p-3">Project</th>
                        <th class="p-3">Status</th>
                        <th class="p-3">Email</th>
                        <th class="p-3">Reacties</th>
                        <th class="p-3"></th>
                    </tr>
                </thead>
                <tbody id="ideasTableBody">
                    <tr id="ideasLoadingRow">
                        <td colspan="8" class="text-center text-muted p-4">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            Laden...
                        </td>
                    </tr>
                    <tr id="ideasEmptyRow" style="display:none">
                        <td colspan="8" class="text-center text-muted p-4">
                            Geen ideeën gevonden.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade"
     id="deleteIdeaModal"
     tabindex="-1"
     aria-labelledby="deleteIdeaModalLabel"
     aria-hidden="true"
     style="display:none">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable mx-3 mx-sm-auto">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteIdeaModalLabel">
                    Idee verwijderen
                </h5>
                <button type="button"
                        class="btn-close"
                        aria-label="Sluiten">
                </button>
            </div>

            <div class="modal-body">
                Ben je zeker dat je het idee
                <strong class="text-break" id="deleteIdeaTitle"></strong>
                wilt verwijderen?
                <br />
                <span class="text-danger">
                    Deze actie kan niet ongedaan gemaakt worden.
                </span>
            </div>

            <div class="modal-footer d-flex flex-column flex-sm-row gap-2">
                <button type="button"
                        class="btn btn-secondary w-100 w-sm-auto"
                        id="cancelDeleteIdeaBtn">
                    Nee
                </button>

                <button type="button" class="btn btn-danger w-100" id="confirmDeleteIdeaBtn">
                    Ja, verwijderen
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade"
     id="deleteReactionModal"
     tabindex="-1"
     aria-labelledby="deleteReactionModalLabel"
     aria-hidden="true"
     style="display:none">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable mx-3 mx-sm-auto">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteReactionModalLabel">
                    Reactie verwijderen
                </h5>
                <button type="button"
                        class="btn-close"
                        aria-label="Sluiten">
                </button>
            </div>

            <div class="modal-body">
                Ben je zeker dat je deze reactie wilt verwijderen?
                <br />
                <span class="text-danger">
                    Deze actie kan niet ongedaan gemaakt worden.
                </span>
            </div>

            <div class="modal-footer d-flex flex-column flex-sm-row gap-2">
                <button type="button"
                        class="btn btn-secondary w-100 w-sm-auto"
                        id="cancelDeleteReactionBtn">
                    Nee
                </button>

                <button type="button" class="btn btn-danger w-100" id="confirmDeleteReactionBtn">
                    Ja, verwijderen
                </button>
            </div>
        </div>
    </div>
</div>
