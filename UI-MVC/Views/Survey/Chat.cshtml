@using IntegratieProject.BL.Domain.questions
@using System.Text.Json
@model QuestionList
@{
    ViewBag.Title = "Survey - Chat";
    Layout = "_Layout";
    var allQuestions = Model.Sections.SelectMany(s => s.Questions).ToList();
    var jsonData = JsonSerializer.Serialize(allQuestions.Select(q => new
    {
        id = q.Id,
        description = q.Description,
        questionType = q.QuestionType.ToString(),
        options = q.Options.Select(o => new { text = o.Text }),
        rangeMin = q.RangeMin,
        rangeMax = q.RangeMax,
        rangeMinLabel = q.RangeMinLabel,
        rangeMaxLabel = q.RangeMaxLabel
    }));
}

<input type="hidden" id="subplatformSlug" value="@ViewBag.SubPlatformSlug" />

<script id="survey-data" type="application/json">
@Html.Raw(jsonData)
</script>

<div class="chatbot-page">
    <div class="chatbot-header">
        <img src="@Model.Project.Logo.Uri" alt="Logo" class="chatbot-logo" />
        <div class="chatbot-header-info">
            <span class="chatbot-name">Echo Assistent</span>
            <span class="chatbot-status">
                <span class="chatbot-status-dot"></span> Online
            </span>
        </div>
    </div>

    <div class="chatbot-window" id="chatWindow">
        <div class="chatbot-messages" id="chatMessages"></div>
    </div>

    <div class="chatbot-input-area" id="chatInputArea"></div>
</div>
