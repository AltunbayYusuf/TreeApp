@using IntegratieProject.BL.Domain.questions
@using IntegratieProject.UI.MVC.Models
@using System.Text.Json
@model QuestionList
@{
    ViewBag.Title = "Survey - Chat";
    Layout = "_Layout";
    var allQuestions = Model?.Sections?
        .Where(s => s != null)
        .SelectMany(s => s.Questions ?? Enumerable.Empty<Question>())
        .ToList() ?? new List<Question>();
    var jsonData = JsonSerializer.Serialize(allQuestions.Select(q => new
    {
        id = q.Id,
        description = q.Description,
        questionType = q.QuestionType.ToString(),
        options = (q.Options ?? Enumerable.Empty<QuestionOption>()).Select(o => new { text = o.Text }),
        rangeMin = q.RangeMin,
        rangeMax = q.RangeMax,
        rangeMinLabel = q.RangeMinLabel,
        rangeMaxLabel = q.RangeMaxLabel
    }));
    var logoUri = Model?.Project?.Logo?.Uri ?? "";
}

<script id="survey-data" type="application/json">
@Html.Raw(jsonData)
</script>

<div class="chatbot-page d-flex flex-column bg-white overflow-hidden" style="font-family: @ProjectFontFamily.ToCssStack(Model?.Project?.FontFamily);">
    <div class="chatbot-header d-flex align-items-center gap-3 py-3 px-4 text-white">
        @if (!string.IsNullOrWhiteSpace(logoUri))
        {
            <img src="@logoUri" alt="Logo" class="chatbot-logo rounded-circle object-fit-cover" />
        }
        <div class="chatbot-header-info d-flex flex-column">
            <span class="fw-bold">Echo Assistent</span>
            <span class="chatbot-status d-flex align-items-center gap-1">
                <span class="chatbot-status-dot"></span> Online
            </span>
        </div>
    </div>

    <div class="chatbot-window" id="chatWindow">
        <div class="chatbot-messages" id="chatMessages"></div>
    </div>

    <div class="chatbot-input-area d-flex align-items-start flex-wrap gap-2 bg-white" id="chatInputArea"></div>
</div>