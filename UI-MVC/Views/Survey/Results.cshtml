@using IntegratieProject.UI.MVC.Models
@model IntegratieProject.BL.Domain.questions.SurveyResponse

@{
    ViewBag.Title = "Bevraging ingevuld";
    Layout = "_Layout";
    var minutes = Model.DurationInSeconds / 60;
    var seconds = Model.DurationInSeconds % 60;
}

<div class="results-page" style="font-family: @ProjectFontFamily.ToCssStack(Model.Project?.FontFamily);">

    <div class="results-header">
        <div class="results-check">&#10003;</div>
        <h1 class="results-title">Bedankt voor je deelname!</h1>
        <p class="results-subtitle">Je hebt de vragenlijst succesvol in  @minutes min @seconds sec   ingevuld. 
            Hieronder vind je een overzicht van jouw antwoorden.</p>
    </div>

    <div class="results-card">
        <p class="results-card-label">Jouw antwoorden</p>
        @{ int i = 1; }
        @foreach (var answer in Model.Answers)
        {
            <div class="results-answer-item">
                <div class="results-answer-q">
                    <span class="results-answer-num">@i</span>
                    <span class="results-answer-question">@answer.Question.Description</span>
                </div>
                <p class="results-answer-value">@answer.Text</p>
            </div>
            i++;
        }
    </div>

    <div class="results-actions">
        <a asp-controller="Idea"
           asp-action="Create"
           asp-route-subplatform="@ViewBag.SubPlatformSlug"
           asp-route-projectId="@Model.Project.Id"
           class="btn results-btn-primary">
            Geef een idee
        </a>

        <a asp-controller="Idea"
           asp-action="Index"
           asp-route-subplatform="@ViewBag.SubPlatformSlug"
           asp-route-projectId="@Model.Project.Id"
           class="btn results-btn-secondary">
            Bekijk andere ideeën
        </a>
    </div>

</div>
