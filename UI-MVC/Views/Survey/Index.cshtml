@using IntegratieProject.BL.Domain.questions
@using IntegratieProject.BL.Domain.Questions
@model IntegratieProject.BL.Domain.questions.QuestionList

@{
    ViewBag.Title = "Survey";
    Layout = "_Layout";
    int questionNumber = 1;
}

<h2 class="text-center mt-4">
    @if (Model.Project?.Logo != null)
    {
        <img src="@Model.Project.Logo.Uri" alt="Logo" class="w-52 h-40">
    }
</h2>

<form asp-controller="Survey"
      asp-action="Submit"
      asp-route-projectId="@Model.Project.Id"
      method="post"
      id="surveyForm">

    @Html.AntiForgeryToken()

    @foreach (var section in Model.Sections.OrderBy(s => s.Order))
    {
        foreach (Question question in section.Questions)
        {
            var conditional = Model.Sections
                .SelectMany(sec => sec.Questions)
                .SelectMany(q => q.ConditionalQuestions)
                .FirstOrDefault(cq => cq.FollowUpQuestion.Id == question.Id);

            <div class="survey-question survey-container mb-5 p-4 @(conditional != null ? "conditional-question d-none" : "")"
                 data-question-id="@question.Id"
                 data-type="@question.QuestionType"
                 data-parent-question-id="@(conditional?.ParentQuestion.Id)"
                 data-trigger-type="@(conditional?.TriggerType)"
                 data-trigger-value="@(conditional?.TriggerValue)">

                <div class="d-flex align-items-start gap-3">

                    <div class="question-number-circle">
                        @if (conditional != null)
                        {
                            <span>↳</span>
                        }
                        else
                        {
                            @questionNumber
                        }
                    </div>

                    <div class="flex-grow-1">

                        <h4 class="survey-question-title">
                            @question.Description
                        </h4>

                        <div class="mb-3">
                            @if (question.QuestionType.ToString() == "SingleChoice")
                            {
                                <span class="badge bg-light text-dark">[ SINGLE CHOICE ]</span>
                            }
                            else if (question.QuestionType.ToString() == "MultipleChoice")
                            {
                                <span class="badge bg-light text-dark">[ MULTIPLE CHOICE ]</span>
                            }
                        </div>

                        <div class="d-flex flex-column gap-2">

                            @if (question.QuestionType.ToString() == "SingleChoice")
                            {
                                foreach (var option in question.Options)
                                {
                                    <label class="survey-option-card d-flex align-items-center">
                                        <input type="radio"
                                               name="question-@question.Id"
                                               value="@option.Text"
                                               class="me-3"/>
                                        <span>@option.Text</span>
                                    </label>
                                }
                            }

                            else if (question.QuestionType.ToString() == "MultipleChoice")
                            {
                                foreach (var option in question.Options)
                                {
                                    <label class="survey-option-card d-flex align-items-center">
                                        <input type="checkbox"
                                               name="question-@question.Id"
                                               value="@option.Text"
                                               class="me-3"/>
                                        <span>@option.Text</span>
                                    </label>
                                }
                            }

                            else if (question.QuestionType.ToString() == "Range")
                            {
                                <div class="d-flex gap-2">
                                    @for (int i = question.RangeMin ?? 1; i <= (question.RangeMax ?? 5); i++)
                                    {
                                        <label class="range-box btn btn-outline-primary">
                                            <input type="radio"
                                                   name="question-@question.Id"
                                                   value="@i"
                                                   class="d-none"/>
                                            @i
                                        </label>
                                    }
                                </div>
                            }

                            @* OPEN *@
                            else if (question.QuestionType.ToString() == "OpenQuestion")
                            {
                                <textarea class="survey-textarea question-text"
                                          name="question-@question.Id"
                                          placeholder="Typ je antwoord hier..."></textarea>
                            }

                        </div>
                    </div>
                </div>
            </div>

            if (conditional == null)
            {
                questionNumber++;
            }
        }
    }

    <div class="text-center mt-5">
        <button type="submit" id="verzendbtn" class="btn btn-primary px-5">
            Verzenden
        </button>
    </div>
</form>
<div class="survey-navigation position-fixed z-3 d-flex flex-column align-items-center gap-2">

    <button type="button"
            id="prevQuestionBtn"
            class="btn survey-nav-btn"
            aria-label="Vorige vraag">
        <span class="fs-3 lh-1">⌃</span>
    </button>

    <button type="button"
            id="nextQuestionBtn"
            class="btn survey-nav-btn"
            aria-label="Volgende vraag">
        <span class="fs-3 lh-1">⌄</span>
    </button>

    <div id="questionProgress" class="survey-nav-progress">
        1/1
    </div>

</div>