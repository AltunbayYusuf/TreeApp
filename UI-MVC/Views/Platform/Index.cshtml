@model IntegratieProject.BL.Domain.project.Platform

@{
    ViewBag.Title = "Platform beheer";
    Layout = "_AdminLayout";
}

<div class="admin-page">
    <div class="admin-header">
        <div>
            <h1 class="admin-title">Platform beheer</h1>
            <p class="admin-subtitle">Beheer alle subplatforms en instellingen</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="admin-form-card text-center py-5">
                <div class="mb-3" style="font-size:3rem;">🏢</div>
                <h2 class="admin-form-title">Welkom, generaal admin</h2>
                <p class="admin-form-subtitle mb-0">Beheer hier het volledige platform en alle subplatforms.</p>
            </div>
        </div>
    </div>
</div>
