@model IntegratieProject.UI.MVC.Models.SubAdminModerationViewModel

@{
    ViewData["Title"] = "Moderatie";
}

<div class="p-6">
    <div class="mb-6">
        <h1 class="text-3xl font-bold">Geblokkeerde content</h1>
        <p class="text-gray-500">Review en valideer ideeën en reacties die door AI moderatie in review zijn geplaatst.</p>
    </div>

    <div class="mb-6 flex flex-wrap gap-2">
        @{
            string FilterClass(string value)
            {
                return Model.ActiveFilter == value
                    ? "bg-black text-white px-4 py-2 rounded text-sm font-medium"
                    : "border px-4 py-2 rounded text-sm font-medium bg-white hover:bg-gray-50";
            }
        }

        <a asp-controller="SubAdminModeration"
           asp-action="Index"
           asp-route-filter="algemeen"
           class="@FilterClass("algemeen")">
            Algemeen
        </a>

        <a asp-controller="SubAdminModeration"
           asp-action="Index"
           asp-route-filter="idee"
           class="@FilterClass("idee")">
            Idee
        </a>

        <a asp-controller="SubAdminModeration"
           asp-action="Index"
           asp-route-filter="reactie"
           class="@FilterClass("reactie")">
            Reactie
        </a>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">

        <!-- LIJST LINKS -->
        <div class="xl:col-span-5">
            <div class="border bg-white">
                <div class="border-b px-4 py-3">
                    <h2 class="font-semibold">In afwachting</h2>
                    <p class="text-sm text-gray-500">@Model.Items.Count item(s) wachten op review</p>
                </div>

                <div class="divide-y">
                    @if (Model.Items.Any())
                    {
                        @foreach (var item in Model.Items)
                        {
                            var itemClass = item.IsSelected
                                ? "block p-4 border-l-4 border-black bg-gray-50"
                                : "block p-4 border-l-4 border-transparent hover:bg-gray-50";

                            var badgeClass = item.Type == "idea"
                                ? "bg-blue-100 text-blue-700"
                                : "bg-purple-100 text-purple-700";

                            <a asp-controller="SubAdminModeration"
                               asp-action="Index"
                               asp-route-filter="@Model.ActiveFilter"
                               asp-route-selectedType="@item.Type"
                               asp-route-selectedId="@item.Id"
                               class="@itemClass">

                                <div class="flex items-start justify-between gap-3 mb-2">
                                    <span class="text-xs font-semibold px-2 py-1 rounded @badgeClass">
                                        @item.Label
                                    </span>
                                </div>

                                <h3 class="font-semibold text-gray-900 mb-1">@item.Title</h3>

                                <p class="text-sm text-gray-600 line-clamp-2 mb-2">
                                    @item.PreviewText
                                </p>

                                <div class="text-xs text-gray-500">
                                    @item.ProjectName
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="p-6 text-gray-500">
                            Geen items gevonden voor deze filter.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- DETAIL RECHTS -->
        <div class="xl:col-span-7">
            <div class="border bg-white min-h-full">
                @if (Model.SelectedItem != null)
                {
                    var selected = Model.SelectedItem;
                    var badgeClass = selected.Type == "idea"
                        ? "bg-blue-100 text-blue-700"
                        : "bg-purple-100 text-purple-700";

                    <div class="p-6 border-b">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <span class="inline-block text-xs font-semibold px-2 py-1 rounded @badgeClass mb-3">
                                    @selected.Label
                                </span>

                                <h2 class="text-3xl font-bold">@selected.Title</h2>
                            </div>
                        </div>
                    </div>

                    <div class="p-6 space-y-6">
                        <div>
                            <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Content:</p>
                            <div class="border p-4 bg-gray-50 text-gray-700">
                                @selected.ContentText
                            </div>
                        </div>

                        <div>
                            <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Reden voor blokkering:</p>
                            <div class="border p-4 bg-orange-50 text-orange-700">
                                @selected.ModerationReason
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Project:</p>
                                <div class="text-gray-700">
                                    @selected.ProjectName
                                </div>
                            </div>
                            
                        </div>

                        @if (selected.Type == "reaction")
                        {
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Reactie op idee:</p>
                                <div class="text-gray-700">
                                    @selected.IdeaTitle
                                </div>
                            </div>
                        }

                        <div class="pt-6 border-t">
                            @if (selected.Type == "idea")
                            {
                                <div class="grid grid-cols-2 gap-4">
                                    <form asp-controller="SubAdminModeration"
                                          asp-action="ApproveIdea"
                                          method="post">
                                        <input type="hidden" name="ideaId" value="@selected.Id" />
                                        <input type="hidden" name="filter" value="@Model.ActiveFilter" />

                                        <button type="submit"
                                                class="w-full bg-green-600 text-white py-3 rounded font-semibold hover:bg-green-700">
                                            Goedkeuren
                                        </button>
                                    </form>

                                    <form asp-controller="SubAdminModeration"
                                          asp-action="RejectIdea"
                                          method="post">
                                        <input type="hidden" name="ideaId" value="@selected.Id" />
                                        <input type="hidden" name="filter" value="@Model.ActiveFilter" />

                                        <button type="submit"
                                                class="w-full bg-red-600 text-white py-3 rounded font-semibold hover:bg-red-700">
                                            Afkeuren
                                        </button>
                                    </form>
                                </div>

                                <p class="text-xs text-gray-400 mt-3 text-center">
                                    Goedgekeurde content wordt direct zichtbaar voor jongeren
                                </p>
                            }
                            else if (selected.Type == "reaction")
                            {
                                <div class="grid grid-cols-2 gap-4">
                                    <form asp-controller="SubAdminModeration"
                                          asp-action="ApproveReaction"
                                          method="post">
                                        <input type="hidden" name="reactionId" value="@selected.Id" />
                                        <input type="hidden" name="filter" value="@Model.ActiveFilter" />

                                        <button type="submit"
                                                class="w-full bg-green-600 text-white py-3 rounded font-semibold hover:bg-green-700">
                                            Goedkeuren
                                        </button>
                                    </form>

                                    <form asp-controller="SubAdminModeration"
                                          asp-action="RejectReaction"
                                          method="post">
                                        <input type="hidden" name="reactionId" value="@selected.Id" />
                                        <input type="hidden" name="filter" value="@Model.ActiveFilter" />

                                        <button type="submit"
                                                class="w-full bg-red-600 text-white py-3 rounded font-semibold hover:bg-red-700">
                                            Afkeuren
                                        </button>
                                    </form>
                                </div>

                                <p class="text-xs text-gray-400 mt-3 text-center">
                                    Goedgekeurde content wordt direct zichtbaar voor jongeren
                                </p>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="p-8 text-gray-500">
                        Geen item geselecteerd.
                    </div>
                }
            </div>
        </div>
    </div>
</div>