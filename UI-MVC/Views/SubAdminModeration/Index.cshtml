@model IntegratieProject.UI.MVC.Models.SubAdminModerationViewModel

@{
    ViewData["Title"] = "Moderatie";
}

<div class="moderation-page">

    <div class="admin-header">
        <div>
            <h1 class="admin-title">Geblokkeerde content</h1>
            <p class="admin-subtitle">Review en valideer ideeën en reacties die door AI moderatie in review zijn geplaatst.</p>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
        @{
            string FilterClass(string value) =>
                Model.ActiveFilter == value ? "mod-filter-btn active" : "mod-filter-btn";
        }

        <a asp-controller="SubAdminModeration"
           asp-action="Index"
           asp-route-filter="algemeen"
           class="@FilterClass("algemeen")">
            Algemeen
        </a>
        <a asp-controller="SubAdminModeration"
           asp-action="Index"
           asp-route-filter="idee"
           class="@FilterClass("idee")">
            Idee
        </a>
        <a asp-controller="SubAdminModeration"
           asp-action="Index"
           asp-route-filter="reactie"
           class="@FilterClass("reactie")">
            Reactie
        </a>
    </div>

    <div class="row g-4">

        <div class="col-12 col-xl-5">
            <div class="moderation-list-card">
                <div class="mod-list-header">
                    <h2>In afwachting</h2>
                    <p>@Model.Items.Count item(s) wachten op review</p>
                </div>

                <div>
                    @if (Model.Items.Any())
                    {
                        @foreach (var item in Model.Items)
                        {
                            var badgeClass = item.Type == "idea" ? "type-idea" : "type-reaction";
                            var selectedClass = item.IsSelected ? "is-selected" : "";

                            <a asp-controller="SubAdminModeration"
                               asp-action="Index"
                               asp-route-filter="@Model.ActiveFilter"
                               asp-route-selectedType="@item.Type"
                               asp-route-selectedId="@item.Id"
                               class="moderation-item @selectedClass">

                                <span class="mod-type-badge @badgeClass">@item.Label</span>
                                <div class="mod-item-title">@item.Title</div>
                                <div class="mod-item-preview">@item.PreviewText</div>
                                <div class="mod-item-project">@item.ProjectName</div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-muted text-center">
                            <div style="font-size:2rem;margin-bottom:0.5rem;">✅</div>
                            Geen items gevonden voor deze filter.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="moderation-detail-card">
                @if (Model.SelectedItem != null)
                {
                    var selected = Model.SelectedItem;
                    var badgeClass = selected.Type == "idea" ? "type-idea" : "type-reaction";

                    <div class="mod-detail-header">
                        <span class="mod-type-badge @badgeClass">@selected.Label</span>
                        <h2 class="fs-4 fw-bold mt-2 mb-0">@selected.Title</h2>
                    </div>

                    <div class="mod-detail-body">
                        <div class="mb-4">
                            <p class="text-muted small fw-bold text-uppercase mb-2" style="letter-spacing:.05em;">Content</p>
                            <div class="mod-content-box">@selected.ContentText</div>
                        </div>

                        <div class="mb-4">
                            <p class="text-muted small fw-bold text-uppercase mb-2" style="letter-spacing:.05em;">Reden voor blokkering</p>
                            <div class="mod-reason-box">@selected.ModerationReason</div>
                        </div>

                        <div class="mb-4">
                            <p class="text-muted small fw-bold text-uppercase mb-2" style="letter-spacing:.05em;">Project</p>
                            <div>@selected.ProjectName</div>
                        </div>

                        @if (selected.Type == "reaction")
                        {
                            <div class="mb-4">
                                <p class="text-muted small fw-bold text-uppercase mb-2" style="letter-spacing:.05em;">Reactie op idee</p>
                                <div>@selected.IdeaTitle</div>
                            </div>
                        }

                        <div class="border-top pt-4">
                            @if (selected.Type == "idea")
                            {
                                <div class="row g-3">
                                    <div class="col-6">
                                        <form asp-controller="SubAdminModeration" asp-action="ApproveIdea" method="post">
                                            <input type="hidden" name="ideaId" value="@selected.Id" />
                                            <input type="hidden" name="filter" value="@Model.ActiveFilter" />
                                            <button type="submit" class="btn btn-success w-100 fw-semibold">Goedkeuren</button>
                                        </form>
                                    </div>
                                    <div class="col-6">
                                        <form asp-controller="SubAdminModeration" asp-action="RejectIdea" method="post">
                                            <input type="hidden" name="ideaId" value="@selected.Id" />
                                            <input type="hidden" name="filter" value="@Model.ActiveFilter" />
                                            <button type="submit" class="btn btn-danger w-100 fw-semibold">Afkeuren</button>
                                        </form>
                                    </div>
                                </div>
                                <p class="text-muted small text-center mt-2">
                                    Goedgekeurde content wordt direct zichtbaar voor jongeren
                                </p>
                            }
                            else if (selected.Type == "reaction")
                            {
                                <div class="row g-3">
                                    <div class="col-6">
                                        <form asp-controller="SubAdminModeration" asp-action="ApproveReaction" method="post">
                                            <input type="hidden" name="reactionId" value="@selected.Id" />
                                            <input type="hidden" name="filter" value="@Model.ActiveFilter" />
                                            <button type="submit" class="btn btn-success w-100 fw-semibold">Goedkeuren</button>
                                        </form>
                                    </div>
                                    <div class="col-6">
                                        <form asp-controller="SubAdminModeration" asp-action="RejectReaction" method="post">
                                            <input type="hidden" name="reactionId" value="@selected.Id" />
                                            <input type="hidden" name="filter" value="@Model.ActiveFilter" />
                                            <button type="submit" class="btn btn-danger w-100 fw-semibold">Afkeuren</button>
                                        </form>
                                    </div>
                                </div>
                                <p class="text-muted small text-center mt-2">
                                    Goedgekeurde content wordt direct zichtbaar voor jongeren
                                </p>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="p-5 text-center text-muted">
                        <div style="font-size:2.5rem;margin-bottom:0.75rem;">🔍</div>
                        <p class="mb-0">Selecteer een item uit de lijst om details te bekijken.</p>
                    </div>
                }
            </div>
        </div>

    </div>
</div>
