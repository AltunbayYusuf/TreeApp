@model IntegratieProject.UI.MVC.Models.SubAdminDashboardViewModel
@using IntegratieProject.BL.Domain.project

<div class="container-fluid p-4 p-md-5">

    <div
        class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="fs-2 fw-bold mb-1">Dashboard</h1>
            <p class="text-muted mb-0">Beheer je participatieprojecten</p>
        </div>

        <a asp-controller="SubAdminProjects"
           asp-action="ProjectInfo"
           asp-route-subplatform="@Model.Slug"
           class="bg-black text-white px-4 py-2 rounded">
            + Nieuw project
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="border p-4 h-100">
                <p class="small text-muted mb-2">Totaal projecten</p>
                <p class="fs-2 fw-bold mb-0">@Model.TotalProjects</p>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="border p-4 h-100 bg-success bg-opacity-10">
                <p class="small text-success mb-2">Actief</p>
                <p class="fs-2 fw-bold text-success mb-0">@Model.ActiveProjects</p>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="border p-4 h-100 bg-primary bg-opacity-10">
                <p class="small text-primary mb-2">Totaal deelnemers</p>
                <p class="fs-2 fw-bold text-primary mb-0">@Model.ParticipantsCount</p>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="border p-4 h-100" style="background-color:#faf5ff;">
                <p class="small mb-2" style="color:#7e22ce;">Totaal ideeën</p>
                <p class="fs-2 fw-bold mb-0" style="color:#7e22ce;">@Model.TotalIdeas</p>
            </div>
        </div>
    </div>

    @* Tabs *@
    <ul class="nav nav-tabs mb-0 border-bottom-0" id="dashboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="projecten-tab" data-bs-toggle="tab"
                    data-bs-target="#tab-projecten" type="button" role="tab">
                Projecten
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="ideeen-tab" data-bs-toggle="tab"
                    data-bs-target="#tab-ideeen" type="button" role="tab">
                Ideeën
            </button>
        </li>
    </ul>

    <div class="tab-content border border-top-0">

        @* Tab: Projecten *@
        <div class="tab-pane fade show active" id="tab-projecten" role="tabpanel">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th class="p-3">Project</th>
                        <th class="p-3">Status</th>
                        <th class="p-3">Vorm</th>
                        <th class="p-3">Deelnemers</th>
                        <th class="p-3">Ideeën</th>
                        <th class="p-3">Aangemaakt</th>
                        <th class="p-3">Acties</th>
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var p in Model.Projects)
                    {
                        var statusClass = p.Status switch
                        {
                            nameof(Status.Active) => "text-success border-success",
                            nameof(Status.Draft) => "text-secondary border-secondary",
                            nameof(Status.Archived) => "text-warning border-warning",
                            _ => ""
                        };

                        <tr>
                            <td class="p-3 fw-semibold">
                                <a asp-controller="Project"
                                   asp-action="Index"
                                   asp-route-subplatform="@Model.Slug"
                                   asp-route-id="@p.Id">
                                    @p.Name
                                </a>
                            </td>

                            <td class="p-3">
                                <span class="px-2 py-1 border @statusClass">
                                    @p.Status
                                </span>
                            </td>

                            <td class="p-3">@p.Form</td>
                            <td class="p-3">@p.ParticipantsCount</td>
                            <td class="p-3">@p.IdeasCount</td>
                            <td class="p-3">@p.ReleaseDate.ToString("d MMM yyyy")</td>

                            <td class="p-3">
                                <div class="d-flex flex-wrap gap-2">
                                    @if (p.Status == nameof(Status.Draft))
                                    {
                                        <form asp-action="UpdateStatus" method="post">
                                            <input type="hidden" name="projectId" value="@p.Id"/>
                                            <input type="hidden" name="status" value="Active"/>
                                            <input type="hidden" name="subplatform" value="@Model.Slug"/>

                                            <button class="btn btn-sm border bg-success bg-opacity-10 text-success">
                                                Actief
                                            </button>
                                        </form>
                                    }

                                    @if (p.Status == nameof(Status.Active))
                                    {
                                        <form asp-action="UpdateStatus" method="post">
                                            <input type="hidden" name="projectId" value="@p.Id"/>
                                            <input type="hidden" name="status" value="Archived"/>
                                            <input type="hidden" name="subplatform" value="@Model.Slug"/>

                                            <button class="btn btn-sm border bg-warning bg-opacity-10 text-warning">
                                                Archief
                                            </button>
                                        </form>
                                    }

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteProjectModal-@p.Id">
                                        🗑️
                                    </button>
                                </div>

                                <div class="modal fade"
                                     id="deleteProjectModal-@p.Id"
                                     tabindex="-1"
                                     aria-labelledby="deleteProjectModalLabel-@p.Id"
                                     aria-hidden="true">
                                    <div
                                        class="modal-dialog modal-dialog-centered modal-dialog-scrollable mx-3 mx-sm-auto">
                                        <div class="modal-content">

                                            <div class="modal-header">
                                                <h5 class="modal-title" id="deleteProjectModalLabel-@p.Id">
                                                    Project verwijderen
                                                </h5>
                                                <button type="button"
                                                        class="btn-close"
                                                        data-bs-dismiss="modal"
                                                        aria-label="Sluiten">
                                                </button>
                                            </div>

                                            <div class="modal-body">
                                                Ben je zeker dat je het project
                                                <strong class="text-break">@p.Name</strong>
                                                wilt verwijderen?
                                                <br/>
                                                <span class="text-danger">
                                                    Deze actie kan niet ongedaan gemaakt worden.
                                                </span>
                                            </div>

                                            <div class="modal-footer d-flex flex-column flex-sm-row gap-2">
                                                <button type="button"
                                                        class="btn btn-secondary w-100 w-sm-auto"
                                                        data-bs-dismiss="modal">
                                                    Nee
                                                </button>

                                                <form asp-controller="SubAdmin"
                                                      asp-action="Delete"
                                                      asp-route-subplatform="@Model.Slug"
                                                      method="post"
                                                      class="w-100 w-sm-auto">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="projectId" value="@p.Id"/>

                                                    <button type="submit" class="btn btn-danger w-100">
                                                        Ja, verwijderen
                                                    </button>
                                                </form>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        @* Tab: Ideeën *@
        <div class="tab-pane fade" id="tab-ideeen" role="tabpanel">

            @* Data mount point voor TypeScript *@
            <span id="subplatformIdData" data-id="@Model.SubPlatformId" class="d-none"></span>

            @* Filter balk *@
            <div class="p-3 border-bottom">

                @* Rij 1: project + datum-sortering rechts *@
                <div class="d-flex flex-column flex-sm-row gap-2 align-items-sm-center mb-2">

                    @* Filter 1: project *@
                    <label class="fw-semibold me-1 mb-0 text-nowrap">Project:</label>
                    <select id="projectFilter" class="form-select form-select-sm w-auto">
                        <option value="">&#8212; Alle ide&#235;en &#8212;</option>
                        @foreach (var p in Model.Projects)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>

                    <span id="ideasCount" class="text-muted small"></span>

                    @* Filter 3: datum-sortering (helemaal rechts) *@
                    <div class="ms-sm-auto d-flex align-items-center gap-2">
                        <label class="fw-semibold mb-0 text-nowrap">Datum:</label>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-dark" data-sort="newest">
                                Nieuwste eerst
                            </button>
                            <button type="button" class="btn btn-outline-secondary" data-sort="oldest">
                                Oudste eerst
                            </button>
                        </div>
                    </div>

                </div>

                <div id="similarityFilterGroup"
                     style="display:none"
                     class="d-flex align-items-center gap-2 flex-wrap">
                    <label class="fw-semibold me-1 mb-0 text-nowrap text-muted">Vergelijking:</label>
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn btn-dark"
                                data-similarity="all" disabled>
                            Alle ide&#235;en
                        </button>
                        <button type="button" class="btn btn-outline-secondary"
                                data-similarity="common" disabled>
                            Gemeenschappelijk
                        </button>
                        <button type="button" class="btn btn-outline-secondary"
                                data-similarity="unique" disabled>
                            Verschillend
                        </button>
                    </div>
                </div>

            </div>

            @* Tabel *@
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th class="p-3">Titel</th>
                        <th class="p-3">Inhoud</th>
                        <th class="p-3">Topic</th>
                        <th class="p-3">Project</th>
                        <th class="p-3">Status</th>
                        <th class="p-3">Reacties</th>
                    </tr>
                    </thead>
                    <tbody id="ideasTableBody">
                    <tr id="ideasLoadingRow" style="display:none">
                        <td colspan="6" class="text-center text-muted p-4">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            Laden&#8230;
                        </td>
                    </tr>
                    <tr id="ideasEmptyRow" style="display:none">
                        <td colspan="6" class="text-center text-muted p-4">Geen ide&#235;en gevonden.</td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>


    </div>
</div>
