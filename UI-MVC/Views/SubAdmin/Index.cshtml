@model IntegratieProject.UI.MVC.Models.SubAdminDashboardViewModel
@using IntegratieProject.BL.Domain.project

<div class="admin-page">

    <div class="admin-header">
        <div>
            <h1 class="admin-title">Projecten</h1>
            <p class="admin-subtitle">Beheer je participatieprojecten</p>
        </div>
        <a asp-controller="SubAdminProjects"
           asp-action="ProjectInfo"
           asp-route-subplatform="@Model.Slug"
           class="btn btn-primary">
            + Nieuw project
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card stat-neutral">
                <div class="stat-label">Totaal projecten</div>
                <p class="stat-value">@Model.TotalProjects</p>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card stat-success">
                <div class="stat-label">Actief</div>
                <p class="stat-value">@Model.ActiveProjects</p>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card stat-primary">
                <div class="stat-label">Totaal deelnemers</div>
                <p class="stat-value">@Model.ParticipantsCount</p>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card stat-secondary">
                <div class="stat-label">Totaal ideeën</div>
                <p class="stat-value">@Model.TotalIdeas</p>
            </div>
        </div>
    </div>

    <div class="admin-table-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Project</th>
                        <th>Status</th>
                        <th>Vorm</th>
                        <th>Deelnemers</th>
                        <th>Ideeën</th>
                        <th>Aangemaakt</th>
                        <th>Acties</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Projects)
                {
                    var statusBadgeClass = p.Status switch
                    {
                        nameof(Status.Active)   => "status-active",
                        nameof(Status.Draft)    => "status-draft",
                        nameof(Status.Archived) => "status-archived",
                        _                       => "status-draft"
                    };

                    <tr>
                        <td class="fw-semibold">
                            <a asp-controller="Project"
                               asp-action="Index"
                               asp-route-subplatform="@Model.Slug"
                               asp-route-id="@p.Id"
                               class="text-decoration-none">
                                @p.Name
                            </a>
                        </td>
                        <td>
                            <span class="status-badge @statusBadgeClass">@p.Status</span>
                        </td>
                        <td class="text-muted small">@p.Form</td>
                        <td>@p.ParticipantsCount</td>
                        <td>@p.IdeasCount</td>
                        <td class="text-muted small">@p.ReleaseDate.ToString("d MMM yyyy")</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                @if (p.Status == nameof(Status.Draft))
                                {
                                    <form asp-action="UpdateStatus" method="post">
                                        <input type="hidden" name="projectId" value="@p.Id" />
                                        <input type="hidden" name="status" value="Active" />
                                        <input type="hidden" name="subplatform" value="@Model.Slug" />
                                        <button class="btn btn-sm btn-outline-success">Activeer</button>
                                    </form>
                                    <a asp-controller="SubAdminProjects"
                                       asp-action="EditDraft"
                                       asp-route-subplatform="@Model.Slug"
                                       asp-route-projectId="@p.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Bewerken
                                    </a>
                                }
                                @if (p.Status == nameof(Status.Active))
                                {
                                    <form asp-action="UpdateStatus" method="post">
                                        <input type="hidden" name="projectId" value="@p.Id" />
                                        <input type="hidden" name="status" value="Archived" />
                                        <input type="hidden" name="subplatform" value="@Model.Slug" />
                                        <button class="btn btn-sm btn-outline-warning">Archiveer</button>
                                    </form>
                                }
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteProjectModal-@p.Id">
                                    🗑️
                                </button>
                                <a asp-controller="SubAdminProjects"
                                   asp-action="CopyAsStartPoint"
                                   asp-route-subplatform="@Model.Slug"
                                   asp-route-projectId="@p.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    Kopieer
                                </a>
                            </div>

                            <div class="modal fade"
                                 id="deleteProjectModal-@p.Id"
                                 tabindex="-1"
                                 aria-labelledby="deleteProjectModalLabel-@p.Id"
                                 aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="deleteProjectModalLabel-@p.Id">
                                                Project verwijderen
                                            </h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            Ben je zeker dat je het project
                                            <strong>@p.Name</strong> wilt verwijderen?
                                            <br/>
                                            <span class="text-danger small">Deze actie kan niet ongedaan gemaakt worden.</span>
                                        </div>
                                        <div class="modal-footer gap-2">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleer</button>
                                            <form asp-controller="SubAdmin"
                                                  asp-action="Delete"
                                                  asp-route-subplatform="@Model.Slug"
                                                  method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="projectId" value="@p.Id" />
                                                <button type="submit" class="btn btn-danger">Ja, verwijderen</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

</div>
