@model IntergratieProject.UI.MVC.Models.SubAdminDashboardViewModel

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}

<div class="p-6">

    <h1 class="text-2xl font-semibold mb-6">
        Dashboard - @Model.SubPlatformName
    </h1>

    @if (!Model.Projects.Any())
    {
        <div class="bg-gray-100 border border-gray-200 rounded-xl p-6 text-center text-gray-600">
            Er zijn geen projecten voor dit deelplatform.
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 justify-center">

            @foreach (var project in Model.Projects)
            {
                var badgeClass = project.Status switch
                {
                    "Active" => "bg-green-100 text-green-700",
                    "Archived" => "bg-red-100 text-red-700",
                    "Draft" => "bg-gray-200 text-gray-700",
                    _ => "bg-gray-100 text-gray-600"
                };

                <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition p-5 flex flex-col justify-between">

                    <div>
                        <h2 class="text-lg font-semibold text-gray-900 mb-2">
                            @project.Name
                        </h2>

                        <span class="inline-block px-3 py-1 text-sm rounded-full @badgeClass">
                            @project.Status
                        </span>
                    </div>

                    <div class="mt-4">
                        <a asp-controller="Project"
                           asp-action="Index"
                           asp-route-subplatform="@Model.Slug"
                           asp-route-id="@project.Id"
                           class="inline-block text-sm font-medium text-white bg-black hover:bg-gray-800 px-4 py-2 rounded-lg transition">
                            Open project
                        </a>
                    </div>

                </div>
            }

        </div>
    }

    <div class="mt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Content in review</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <div class="bg-white rounded-2xl shadow-sm p-6 border border-gray-100">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Ideeën in review</h3>

                @if (Model.IdeasReviews == null || !Model.IdeasReviews.Any())
                {
                    <p class="text-gray-500">Geen ideeën in review.</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var idea in Model.IdeasReviews)
                        {
                            <div class="border border-gray-200 rounded-xl p-4">
                                <div class="text-sm text-gray-500 mb-1">@idea.ProjectName</div>
                                <div class="font-semibold text-gray-900">@idea.Title</div>
                                <div class="text-sm text-gray-500 mb-2">Topic: @idea.TopicTheme</div>
                                <p class="text-gray-700">@idea.Text</p>
                                <div class="mt-3 text-sm font-medium text-orange-600">
                                    Status: @idea.ModerationStatus
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="bg-white rounded-2xl shadow-sm p-6 border border-gray-100">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Reacties in review</h3>

                @if (Model.ReactionsReviews == null || !Model.ReactionsReviews.Any())
                {
                    <p class="text-gray-500">Geen reacties in review.</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var reaction in Model.ReactionsReviews)
                        {
                            <div class="border border-gray-200 rounded-xl p-4">
                                <div class="text-sm text-gray-500 mb-1">@reaction.ProjectName</div>
                                <div class="font-semibold text-gray-900">Op idee: @reaction.IdeaTitle</div>

                                @if (!string.IsNullOrWhiteSpace(reaction.Text))
                                {
                                    <p class="text-gray-700 mt-2">@reaction.Text</p>
                                }

                                @if (!string.IsNullOrWhiteSpace(reaction.Emoji))
                                {
                                    <div class="text-2xl mt-2">@reaction.Emoji</div>
                                }

                                <div class="mt-3 text-sm font-medium text-orange-600">
                                    Status: @reaction.ModerationStatus
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    </div>

</div>