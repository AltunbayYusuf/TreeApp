@model IntegratieProject.UI.MVC.Models.SubAdminDashboardViewModel
@using IntegratieProject.BL.Domain.project

<div class="container-fluid p-4 p-md-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="fs-2 fw-bold mb-1">Projecten</h1>
            <p class="text-muted mb-0">Beheer je participatieprojecten</p>
        </div>
        
        <a asp-controller="SubAdminProjects"
           asp-action="ProjectInfo"
           asp-route-subplatform="@Model.Slug"
           class="bg-black text-white px-4 py-2 rounded">
            + Nieuw project
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="border p-4 h-100">
                <p class="small text-muted mb-2">Totaal projecten</p>
                <p class="fs-2 fw-bold mb-0">@Model.TotalProjects</p>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="border p-4 h-100 bg-success bg-opacity-10">
                <p class="small text-success mb-2">Actief</p>
                <p class="fs-2 fw-bold text-success mb-0">@Model.ActiveProjects</p>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="border p-4 h-100 bg-primary bg-opacity-10">
                <p class="small text-primary mb-2">Totaal deelnemers</p>
                <p class="fs-2 fw-bold text-primary mb-0">@Model.ParticipantsCount</p>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="border p-4 h-100" style="background-color:#faf5ff;">
                <p class="small mb-2" style="color:#7e22ce;">Totaal ideeën</p>
                <p class="fs-2 fw-bold mb-0" style="color:#7e22ce;">@Model.TotalIdeas</p>
            </div>
        </div>
    </div>

    <div class="border table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th class="p-3">Project</th>
                <th class="p-3">Status</th>
                <th class="p-3">Vorm</th>
                <th class="p-3">Deelnemers</th>
                <th class="p-3">Ideeën</th>
                <th class="p-3">Aangemaakt</th>
                <th class="p-3">Acties</th>
            </tr>
            </thead>

            <tbody>
            @foreach (var p in Model.Projects)
            {
                var statusClass = p.Status switch
                {
                    nameof(Status.Active) => "text-success border-success",
                    nameof(Status.Draft) => "text-secondary border-secondary",
                    nameof(Status.Archived) => "text-warning border-warning",
                    _ => ""
                };

                <tr>
                    <td class="p-3 fw-semibold">
                        <a asp-controller="Project"
                           asp-action="Index"
                           asp-route-subplatform="@Model.Slug"
                           asp-route-id="@p.Id">
                            @p.Name
                        </a>
                    </td>

                    <td class="p-3">
                        <span class="px-2 py-1 border @statusClass">
                            @p.Status
                        </span>
                    </td>

                    <td class="p-3">@p.Form</td>
                    <td class="p-3">@p.ParticipantsCount</td>
                    <td class="p-3">@p.IdeasCount</td>
                    <td class="p-3">@p.ReleaseDate.ToString("d MMM yyyy")</td>

                    <td class="p-3">
                        <div class="d-flex flex-wrap gap-2">
                            @if (p.Status == nameof(Status.Draft))
                            {
                                <form asp-action="UpdateStatus" method="post">
                                    <input type="hidden" name="projectId" value="@p.Id" />
                                    <input type="hidden" name="status" value="Active" />

                                    <button class="btn btn-sm border bg-success bg-opacity-10 text-success">
                                        Actief
                                    </button>
                                </form>
                                <a asp-controller="SubAdminProjects"
                                   asp-action="EditDraft"
                                   asp-route-projectId="@p.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Bewerken
                                </a>
                            
                            }

                            @if (p.Status == nameof(Status.Active))
                            {
                                <form asp-action="UpdateStatus" method="post">
                                    <input type="hidden" name="projectId" value="@p.Id" />
                                    <input type="hidden" name="status" value="Archived" />

                                    <button class="btn btn-sm border bg-warning bg-opacity-10 text-warning">
                                        Archief
                                    </button>
                                </form>
                            }

                            <a asp-controller="SubAdminProjects"
                               asp-action="Statistics"
                               asp-route-subplatform="@Model.Slug"
                               asp-route-projectId="@p.Id"
                               class="btn btn-sm btn-outline-dark">
                                Statistieken
                            </a>

                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteProjectModal-@p.Id">
                                🗑️
                            </button>
                            <a asp-controller="SubAdminProjects"
                               asp-action="CopyAsStartPoint"
                               asp-route-projectId="@p.Id"
                               class="btn btn-sm btn-outline-primary">
                                Startpunt Project
                            </a>
                        </div>

                        <div class="modal fade"
                             id="deleteProjectModal-@p.Id"
                             tabindex="-1"
                             aria-labelledby="deleteProjectModalLabel-@p.Id"
                             aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable mx-3 mx-sm-auto">
                                <div class="modal-content">

                                    <div class="modal-header">
                                        <h5 class="modal-title" id="deleteProjectModalLabel-@p.Id">
                                            Project verwijderen
                                        </h5>
                                        <button type="button"
                                                class="btn-close"
                                                data-bs-dismiss="modal"
                                                aria-label="Sluiten">
                                        </button>
                                    </div>

                                    <div class="modal-body">
                                        Ben je zeker dat je het project
                                        <strong class="text-break">@p.Name</strong>
                                        wilt verwijderen?
                                        <br/>
                                        <span class="text-danger">
                                            Deze actie kan niet ongedaan gemaakt worden.
                                        </span>
                                    </div>

                                    <div class="modal-footer d-flex flex-column flex-sm-row gap-2">
                                        <button type="button"
                                                class="btn btn-secondary w-100 w-sm-auto"
                                                data-bs-dismiss="modal">
                                            Nee
                                        </button>

                                        <form asp-controller="SubAdmin"
                                              asp-action="Delete"
                                              method="post"
                                              class="w-100 w-sm-auto">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="projectId" value="@p.Id" />

                                            <button type="submit" class="btn btn-danger w-100">
                                                Ja, verwijderen
                                            </button>
                                        </form>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

</div>