@model IntegratieProject.BL.Domain.Statistics.ProjectStatistics

@{
    ViewBag.Title = "Projectstatistieken";
    Layout = "_Layout";
}

<div class="container-fluid px-4 px-md-5 py-4">

    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="fs-2 fw-bold mb-1">Statistieken</h1>
            <p class="text-muted mb-0">@Model.ProjectName</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="SubAdminProjects"
               asp-action="ExportStatisticsCsv"
               asp-route-subplatform="@ViewContext.RouteData.Values["subplatform"]"
               asp-route-projectId="@Model.ProjectId"
               class="btn btn-success btn-sm d-flex justify-content-center align-items-center">
                Exporteer CSV
            </a>

            <a asp-controller="SubAdmin"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Terug naar dashboard
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <p class="text-muted small mb-2">Deelnemers</p>
                    <p class="display-6 fw-bold mb-0">@Model.ParticipantsCount</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <p class="text-muted small mb-2">Ideeën</p>
                    <p class="display-6 fw-bold mb-0">@Model.IdeasCount</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <p class="text-muted small mb-2">Reacties</p>
                    <p class="display-6 fw-bold mb-0">@Model.ReactionsCount</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var question in Model.Questions)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">

                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
                            <div>
                                <h2 class="fs-5 fw-bold mb-2">@question.Question</h2>
                                <p class="text-muted small mb-0">
                                    Type: @question.QuestionType |
                                    Antwoorden: @question.TotalAnswers
                                </p>
                            </div>

                            @if (question.Average.HasValue)
                            {
                                <span class="badge text-bg-primary rounded-pill px-3 py-2">
                                    Gem. @question.Average
                                </span>
                            }
                        </div>

                        @if (question.Options.Any())
                        {
                            var maxPercentage = question.Options.Max(o => o.Percentage);

                            <div class="overflow-auto">
                                <div class="d-flex align-items-end gap-4 pb-3" style="height:260px;">

                                    @for (var i = 0; i < question.Options.Count; i++)
                                    {
                                        var option = question.Options[i];
                                        var barColors = new[] { "#4f46e5", "#0ea5e9", "#10b981", "#f59e0b", "#ef4444", "#8b5cf6", "#ec4899", "#14b8a6" };
                                        var barColor = barColors[i % barColors.Length];
                                        var barHeight = maxPercentage == 0
                                            ? 0
                                            : Math.Max((option.Percentage / maxPercentage) * 170, 12);

                                        <div class="d-flex flex-column align-items-center justify-content-end flex-shrink-0 w-25">

                                            <div class="small fw-semibold mb-2">
                                                @option.Percentage%
                                            </div>

                                            <div class="rounded-top w-75"
                                                 title="@option.Answer - @option.Count antwoorden"
                                                 style="height:@(barHeight)px; background-color:@barColor;">
                                            </div>

                                            <div class="small text-muted mt-2 text-center">
                                                @option.Count antw.
                                            </div>

                                            <div class="small fw-semibold text-center text-wrap w-100"
                                                 title="@option.Answer">
                                                @option.Answer
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else if (question.QuestionType == "OpenQuestion")
                        {
                            @if (question.OpenAnswers.Any())
                            {
                                <div class="mb-3">
                                    <h3 class="fs-6 fw-bold mb-2">Open antwoorden</h3>

                                    <div class="d-flex flex-column gap-2">
                                        @foreach (var answer in question.OpenAnswers)
                                        {
                                            <div class="border rounded p-3 bg-white">
                                                @answer
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="card bg-light border">
                                <div class="card-body">
                                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-3">
                                        <div>
                                            <h3 class="fs-6 fw-bold mb-1">AI-samenvatting open antwoorden</h3>

                                            @if (question.AiSummaryGeneratedAt.HasValue)
                                            {
                                                <p class="text-muted small mb-0">
                                                    Laatst gegenereerd:
                                                    @question.AiSummaryGeneratedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                </p>
                                            }
                                        </div>

                                        @if (string.IsNullOrWhiteSpace(question.AiSummary) || question.AiSummaryNeedsRefresh)
                                        {
                                            <form class="open-question-summary-form"
                                                  asp-controller="SubAdminProjects"
                                                  asp-action="GenerateOpenQuestionSummary"
                                                  asp-route-subplatform="@ViewContext.RouteData.Values["subplatform"]"
                                                  asp-route-projectId="@Model.ProjectId"
                                                  asp-route-questionId="@question.QuestionId"
                                                  method="post"
                                                  data-question-id="@question.QuestionId">

                                                @Html.AntiForgeryToken()

                                                <button type="submit"
                                                        class="btn btn-primary btn-sm open-question-summary-button">
                                                    @(string.IsNullOrWhiteSpace(question.AiSummary)
                                                        ? "Genereer samenvatting"
                                                        : "Vernieuw samenvatting")
                                                </button>
                                            </form>

                                            <div class="alert alert-info d-none mt-2 open-question-loading">
                                                AI genereert samenvatting...
                                            </div>

                                            <div class="alert alert-danger d-none mt-2 open-question-error">
                                                AI kon geen samenvatting genereren.
                                            </div>
                                        }
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(question.AiSummary))
                                    {
                                        <p class="mb-0">@question.AiSummary</p>
                                    }
                                    else
                                    {
                                        <p class="text-muted mb-0">
                                            Nog geen AI-samenvatting gegenereerd.
                                        </p>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light border mb-0">
                                Geen gesloten statistieken beschikbaar voor deze vraag.
                            </div>
                        }

                    </div>
                </div>
            </div>
        }
    </div>
    <div class="card border-0 shadow-sm mt-4" id="projectSummaryCard">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h2 class="fs-5 fw-bold mb-1">Algemene AI-samenvatting</h2>
                    <p class="text-muted small mb-0">
                        Vat de volledige statistieken, ideeën en reacties van dit project samen.
                    </p>
                </div>

                <form id="projectSummaryForm"
                      asp-controller="SubAdminProjects"
                      asp-action="GenerateProjectTrendSummary"
                      asp-route-subplatform="@ViewContext.RouteData.Values["subplatform"]"
                      asp-route-projectId="@Model.ProjectId"
                      method="post">
                    @Html.AntiForgeryToken()

                    <button id="projectSummaryButton" type="submit" class="btn btn-primary btn-sm">
                        Genereer algemene samenvatting
                    </button>
                </form>
            </div>

            <div id="projectSummaryLoading" class="alert alert-info d-none mb-3">
                AI genereert samenvatting...
            </div>

            <div id="projectSummaryError" class="alert alert-danger d-none mb-3">
                AI kon geen samenvatting genereren. Probeer opnieuw.
            </div>

            <p id="projectSummaryResult" class="mb-0 text-muted">
                Nog geen algemene AI-samenvatting gegenereerd.
            </p>
        </div>
    </div>
</div>
