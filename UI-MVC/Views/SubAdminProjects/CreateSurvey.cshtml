@using IntegratieProject.BL.Domain.questions
@model IntegratieProject.UI.MVC.Models.CreateProjecSurveyViewModel

@{
    ViewBag.Title = "Nieuw project aanmaken";
    Layout = "_AdminLayout";

    var initialSurveyData = Model.Sections.Select(s => new
    {
        title = s.Title,
        questions = s.Questions.Select(q => new
        {
            title = q.Description,
            type = q.QuestionType switch
            {
                QuestionType.SingleChoice => "single",
                QuestionType.MultipleChoice => "multiple",
                QuestionType.Range => "range",
                _ => "open"
            },
            answers = q.Options ?? new List<string>(),
            min = q.RangeMin?.ToString() ?? "",
            max = q.RangeMax?.ToString() ?? "",
            conditionals = q.Conditionals.Select(c => new
            {
                trigger = c.Trigger,
                triggerType = c.TriggerType.ToString(),
                ai = c.UseAi,
                question = c.QuestionText
            })
        })
    });
}

<div class="admin-page">

    <div class="admin-header">
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="SubAdmin"
               asp-action="Index"
               class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center"
               style="width:38px;height:38px;border-radius:8px;">
                ←
            </a>
            <div>
                <h1 class="admin-title">Nieuw project aanmaken</h1>
                <span class="badge bg-secondary">Draft</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary">Preview</button>
            <button type="submit" form="surveyForm" class="btn btn-primary">Opslaan</button>
        </div>
    </div>

    <nav class="admin-tabs mb-4">
        <a asp-controller="SubAdminProjects"
           asp-action="ProjectInfo"
           class="admin-tab-link">Project Info</a>
        <button type="button" class="admin-tab-link active">Bevraging</button>
        <a asp-controller="SubAdminProjects"
           asp-action="CreateIdeation"
           class="admin-tab-link">Ideation</a>
    </nav>

        <form id="surveyForm"
              data-save-url="/api/subadmin-projects/survey"
              data-ai-url="/api/subadmin-projects/survey/ai"
              class="space-y-6">

        @Html.AntiForgeryToken()

        <div id="surveyError" class="alert alert-danger d-none"></div>
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="ai-assistant-card mb-4">
            <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
                <div class="flex-grow-1">
                    <div class="ai-card-title">✨ AI Vragenlijst Assistent</div>
                    <div class="ai-card-subtitle">
                        Beschrijf wat je wil weten van jongeren. De AI maakt gewone vragen aan,
                        zonder conditionele bijvragen. Bijvragen voeg je daarna zelf toe.
                    </div>
                </div>
                <div style="min-width:120px;">
                    <label for="questionAmount" class="form-label small fw-semibold">Aantal vragen</label>
                    <input id="questionAmount"
                           type="number"
                           min="1"
                           max="20"
                           value="5"
                           class="form-control form-control-sm"/>
                </div>
            </div>

            <textarea id="aiPrompt"
                      rows="4"
                      class="form-control mt-3"
                      placeholder="bv. Ik wil begrijpen welke stressfactoren studenten ervaren en welke ondersteuning ze verwachten van de school..."></textarea>

            <div class="d-flex align-items-center gap-3 mt-3">
                <button type="button"
                        id="generateSurveyWithAiBtn"
                        class="btn-ai btn">
                    Genereer vragenlijst
                </button>
                <span id="surveyAiMessage" class="ai-message"></span>
            </div>

            <div id="surveyAiError" class="alert alert-danger d-none mt-3"></div>
        </div>

        <div class="survey-builder-card">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <button type="button"
                        onclick="addSection()"
                        class="btn btn-outline-secondary btn-sm">
                    + Sectie toevoegen
                </button>
                <span id="questionCounter" class="question-counter-badge">0 / 20 vragen</span>
            </div>

            <div id="sections"></div>
        </div>

    </form>
</div>

<script id="initialSurveyData" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(initialSurveyData))
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
