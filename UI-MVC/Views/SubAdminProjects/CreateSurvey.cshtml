@model IntergratieProject.UI.MVC.Models.CreateProjecSurveyViewModel

@{
    ViewData["Title"] = "Bevraging maken";
}

<script src="~/js/createSurvey.js" defer></script>

<div class="min-h-screen bg-slate-50 py-8">
    <div class="max-w-6xl mx-auto px-5 py-6">

        <div class="flex items-start justify-between border-b border-slate-200 pb-5 mb-6">
            <div class="flex items-start gap-4">
                <a asp-controller="SubAdmin"
                   asp-action="Index"
                   asp-route-subplatform="@Model.SubplatformSlug"
                   class="inline-flex h-11 w-11 items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 transition">
                    ←
                </a>

                <div>
                    <h1 class="text-2xl font-semibold text-slate-900">Nieuw project aanmaken</h1>
                    <p class="text-sm text-slate-500 mt-1">Status: Draft</p>
                </div>
            </div>

            <div class="flex gap-3">
                <button type="button"
                        class="inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition">
                    Preview
                </button>

                <button type="submit"
                        form="createProjectForm"
                        class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-indigo-700 transition shadow-sm">
                    Opslaan
                </button>
            </div>
        </div>

        <div class="mb-6 border-b border-slate-200">
            <div class="flex gap-2">
                <a asp-controller="SubAdminProjects"
                   asp-action="ProjectInfo"
                   asp-route-subplatform="@Model.SubplatformSlug"
                   class="rounded-t-lg border border-b-0 border-transparent bg-slate-100 px-5 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-200 transition">
                    Project Info
                </a>

                <button type="button"
                   class="rounded-t-lg border border-b-0 border-slate-200 bg-white px-5 py-2.5 text-sm font-medium text-slate-900 shadow-sm">
                    Bevraging
                </button>

                <button type="button"
                        class="rounded-t-lg border border-b-0 border-transparent bg-slate-100 px-5 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-200 transition">
                    Ideation
                </button>
            </div>
        </div>


        <div class="max-w-4xl mx-auto px-4">

            <div class="border-2 border-purple-300 bg-purple-50 rounded-xl p-6 mb-6 shadow-sm">
                <h3 class="text-lg font-semibold text-slate-900 mb-2">AI Vragenlijst Assistent</h3>
                <p class="text-sm text-slate-600 mb-3">
                    Beschrijf wat je wil weten van jongeren
                </p>

                <textarea id="aiPrompt"
                          class="w-full rounded-lg border border-slate-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-500"
                          placeholder="bv. Ik wil begrijpen welke stressfactoren studenten ervaren..."></textarea>

                <button
                    class="mt-3 bg-purple-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-purple-700 transition">
                    Genereer vragenlijst
                </button>
            </div>

            <!-- TOOLBAR -->
            <div class="flex items-center justify-between mb-4">
                <div class="flex gap-2">
                    <button onclick="addSection()"
                            class="bg-white border border-slate-300 px-4 py-2 rounded-lg text-sm hover:bg-slate-100 transition">
                        + Sectie toevoegen
                    </button>
                </div>

                <span id="questionCounter" class="text-sm text-slate-600 font-medium">
                0 / 20 vragen
            </span>
            </div>

            <div id="sections" class="space-y-4"></div>

        </div>
    </div>
</div>