@using IntegratieProject.BL.Domain.questions
@model IntegratieProject.UI.MVC.Models.CreateProjecSurveyViewModel

@{
    ViewBag.Title = "Nieuw project aanmaken";
    Layout = "_AdminLayout";

    var initialSurveyData = Model.Sections.Select(s => new
    {
        title = s.Title,
        questions = s.Questions.Select(q => new
        {
            title = q.Description,
            type = q.QuestionType switch
            {
                QuestionType.SingleChoice => "single",
                QuestionType.MultipleChoice => "multiple",
                QuestionType.Range => "range",
                _ => "open"
            },
            answers = q.Options ?? new List<string>(),
            min = q.RangeMin?.ToString() ?? "",
            max = q.RangeMax?.ToString() ?? "",
            conditionals = q.Conditionals.Select(c => new
            {
                trigger = c.Trigger,
                triggerType = c.TriggerType.ToString(),
                ai = c.UseAi,
                question = c.QuestionText
            })
        })
    });
}

<div class="admin-page py-4">

    <div class="admin-header mb-4">
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="SubAdmin"
               asp-action="Index"
               class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center"
               style="width:38px;height:38px;border-radius:8px;">
                ←
            </a>
            <div>
                <h1 class="admin-title text-body-emphasis fw-bold mb-1">Nieuw project aanmaken</h1>
                <span class="badge text-bg-secondary">Draft</span>
            </div>
        </div>
    </div>

    <nav class="admin-tabs bg-transparent mb-4">
        <button type="submit"
                form="surveyForm"
                class="admin-tab-link text-body-emphasis"
                data-redirect-url="@Url.Action("ProjectInfo", "SubAdminProjects", new { subplatform = Model.SubplatformSlug })">
            Project Info
        </button>
        <button type="button" class="admin-tab-link active">Bevraging</button>
        <button type="submit"
                form="surveyForm"
                class="admin-tab-link text-body-emphasis"
                data-redirect-url="@Url.Action("CreateIdeation", "SubAdminProjects", new { subplatform = Model.SubplatformSlug })">
            Ideation
        </button>
    </nav>

    <form id="surveyForm"
          data-save-url="/api/subadmin-projects/survey"
          data-ai-url="/api/subadmin-projects/survey/ai"
          data-finalize-url="@Url.Action("FinalizeProject", "SubAdminProjects", new { subplatform = Model.SubplatformSlug })"
          class="space-y-6">

        @Html.AntiForgeryToken()

        <div id="surveyError" class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger d-none"></div>
        <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger"></div>

        <div class="ai-assistant-card bg-transparent border border-secondary rounded-4 p-4 mb-4 shadow-sm">
            <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
                <div class="flex-grow-1">
                    <div class="ai-card-title text-body-emphasis fw-bold mb-1">✨ AI Vragenlijst Assistent</div>

                    <div class="ai-card-subtitle text-body-secondary">
                        Beschrijf wat je wil weten van jongeren. De AI maakt gewone vragen aan,
                        zonder conditionele bijvragen. Bijvragen voeg je daarna zelf toe.
                    </div>
                </div>

                <div style="min-width:120px;">
                    <label for="questionAmount" class="form-label small fw-semibold text-body-emphasis">Aantal vragen</label>

                    <input id="questionAmount"
                           type="number"
                           min="1"
                           max="20"
                           value="5"
                           class="form-control form-control-sm bg-transparent text-body-emphasis border-secondary"/>
                </div>

                <div class="w-100">
                    <textarea id="aiPromptInput"
                              class="form-control mt-3 bg-transparent text-body-tertiary border-secondary"
                              rows="3"
                              placeholder="bv. Ik wil begrijpen welke stressfactoren studenten ervaren en welke ondersteuning ze verwachten van de school..."></textarea>
                </div>

                <div class="w-100">
                    <button type="button" id="generateQuestionsBtn" class="btn btn-primary mt-2">
                        Genereer vragenlijst
                    </button>
                </div>
            </div>

            <div id="surveyAiError" class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger d-none mt-3"></div>
        </div>

        <div class="survey-builder-card bg-transparent border border-secondary rounded-4 p-4 mb-4 shadow-sm">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <button type="button"
                        onclick="addSection()"
                        class="btn btn-outline-secondary text-body-emphasis btn-sm">
                    + Sectie toevoegen
                </button>
                <span id="questionCounter" class="question-counter-badge badge border border-secondary bg-body-tertiary text-body-emphasis px-3 py-2 fs-6 fw-semibold">0 / 20 vragen</span>            </div>

            <div id="sections"></div>
        </div>
        
        <div class="d-flex justify-content-end gap-2 mt-4">
            <button type="submit"
                    form="surveyForm"
                    class="btn btn-primary px-4 py-2"
                    data-final-save>
                Opslaan
            </button>
        </div>
    </form>
</div>

<script id="initialSurveyData" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(initialSurveyData))
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
