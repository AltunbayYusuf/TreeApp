@model IntegratieProject.UI.MVC.Models.CreateProjectIdeationViewModel

@{
    ViewBag.Title = "Nieuw project aanmaken";
    Layout = "_Layout";
}

<div class="bg-slate-50 min-h-screen">
    <div class="max-w-6xl mx-auto px-5 py-6">
        <div class="flex items-start justify-between border-b border-slate-200 pb-5 mb-6">
            <div class="flex items-start gap-4">
                <a asp-controller="SubAdmin"
                   asp-action="Index"
                   asp-route-subplatform="@Model.SubplatformSlug"
                   class="inline-flex h-11 w-11 items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 transition">
                    ←
                </a>

                <div>
                    <h1 class="text-2xl font-semibold text-slate-900">Nieuw project aanmaken</h1>
                    <p class="text-sm text-slate-500 mt-1">Status: Draft</p>
                </div>
            </div>

            <div class="flex gap-3">
                <button type="button"
                        class="inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition">
                    Preview
                </button>

                <button type="submit"
                        form="ideationForm"
                        class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-indigo-700 transition shadow-sm">
                    Opslaan
                </button>
            </div>
        </div>

        <div class="mb-6 border-b border-slate-200">
            <div class="flex gap-2">
                <a asp-controller="SubAdminProjects"
                   asp-action="ProjectInfo"
                   asp-route-subplatform="@Model.SubplatformSlug"
                   class="rounded-t-lg border border-b-0 border-transparent bg-slate-100 px-5 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-200 transition">
                    Project Info
                </a>

                <a asp-controller="SubAdminProjects"
                   asp-action="CreateSurvey"
                   asp-route-subplatform="@Model.SubplatformSlug"
                   class="rounded-t-lg border border-b-0 border-transparent bg-slate-100 px-5 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-200 transition">
                    Bevraging
                </a>

                <button type="button"
                        class="rounded-t-lg border border-b-0 border-slate-200 bg-white px-5 py-2.5 text-sm font-medium text-slate-900 shadow-sm">
                    Ideation
                </button>
            </div>
        </div>

        <form id="ideationForm"
              asp-controller="SubAdminProjects"
              asp-action="SaveIdeation"
              asp-route-subplatform="@Model.SubplatformSlug"
              method="post"
              class="space-y-6">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

            @if (TempData["IdeationSavedMessage"] is string savedMessage)
            {
                <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                    @savedMessage
                </div>
            }

            <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
                <h2 class="text-2xl font-semibold text-slate-900 mb-2">Ideation Topics</h2>
                <p class="text-sm text-slate-500 mb-6">
                    Stel de topics in waarvoor jongeren ideeën kunnen geven. Dit kan 1 topic zijn, maar ook meerdere.
                </p>

                <div id="topicsContainer" class="space-y-4">
                    @for (var i = 0; i < Model.Topics.Count; i++)
                    {
                        <div class="topic-card rounded-2xl border border-slate-200 bg-slate-50 p-5" data-index="@i">
                            <div class="flex items-start justify-between mb-3">
                                <h3 class="topic-label text-sm font-semibold text-slate-700">Topic @(i + 1)</h3>

                                <button type="button"
                                        class="remove-topic-btn inline-flex h-11 w-11 items-center justify-center rounded-lg border border-red-200 bg-white text-red-500 hover:bg-red-50 transition">
                                    🗑
                                </button>
                            </div>

                            <div class="flex gap-3 items-start">
                                <div class="flex-1">
                                    <input name="Topics[@i].Title"
                                           id="Topics_@(i)__Title"
                                           value="@Model.Topics[i].Title"
                                           class="topic-title w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-100"
                                           placeholder="bv. Acties om mentaal welzijn te verbeteren" />

                                    <span class="topic-title-validation mt-1 block text-sm text-red-600"
                                          data-valmsg-for="Topics[@i].Title"
                                          data-valmsg-replace="true"></span>
                                </div>
                            </div>

                            <div class="mt-4">
                                <textarea name="Topics[@i].Description"
                                          id="Topics_@(i)__Description"
                                          rows="4"
                                          class="topic-description w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-100"
                                          placeholder="Beschrijving/context voor dit topic (optioneel)...">@Model.Topics[i].Description</textarea>

                                <span class="topic-description-validation mt-1 block text-sm text-red-600"
                                      data-valmsg-for="Topics[@i].Description"
                                      data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    }
                </div>

                <button type="button"
                        id="addTopicButton"
                        class="mt-4 inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition">
                    + Topic toevoegen
                </button>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
                <div class="flex items-center gap-2 mb-2">
                    <h2 class="text-2xl font-semibold text-slate-900">AI Doorvraag Prompts</h2>
                    <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 text-xs text-slate-500">?</span>
                </div>

                <p class="text-sm text-slate-500 mb-6">
                    AI stelt gerichte vragen om ideeën te verdiepen. Pas de prompt aan voor betere context.
                </p>

                <div class="mb-6">
                    <label asp-for="ProjectContext" class="block text-sm font-semibold text-slate-800 mb-2">
                        Context over het project
                    </label>
                    <textarea asp-for="ProjectContext"
                              rows="5"
                              class="w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-100"
                              placeholder="bv. Dit gaat over een hogeschool die haar studenten (17-25 jaar) wil ondersteunen..."></textarea>
                    <span asp-validation-for="ProjectContext" class="mt-1 block text-sm text-red-600"></span>
                </div>

                <div>
                    <label asp-for="IdeaInfo" class="block text-sm font-semibold text-slate-800 mb-2">
                        Gewenste informatie over ideeën
                    </label>
                    <textarea asp-for="IdeaInfo"
                              rows="5"
                              class="w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-100"
                              placeholder="bv. We willen weten: Wie organiseert het? Hoe vaak? Wat kost het? Hoe bereik je studenten?..."></textarea>
                    <span asp-validation-for="IdeaInfo" class="mt-1 block text-sm text-red-600"></span>
                </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
                <h2 class="text-2xl font-semibold text-slate-900 mb-2">AI-selectie instellingen</h2>
                <p class="text-sm text-slate-500 mb-6">
                    Stel in hoeveel ideeën tegelijk getoond worden.
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label asp-for="IdeasPerBatch" class="block text-sm font-semibold text-slate-800 mb-2">
                            Aantal ideeën per keer
                        </label>
                        <input asp-for="IdeasPerBatch"
                               type="number"
                               min="3"
                               max="10"
                               class="w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-100" />
                        <span asp-validation-for="IdeasPerBatch" class="mt-1 block text-sm text-red-600"></span>
                    </div>
                </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
                <h2 class="text-2xl font-semibold text-slate-900 mb-2">Reacties</h2>
                <p class="mt-3 text-sm text-slate-500">Kies de emoji-groep die je wilt tonen.</p>

                <input asp-for="SelectedEmojiGroup" type="hidden" id="SelectedEmojiGroup" />

                <div id="emojiGroups" class="space-y-3">
                    <button type="button"
                            class="emoji-group flex gap-4 rounded-lg border border-slate-300 px-4 py-3 text-3xl hover:bg-slate-50"
                            data-selected="false"
                            data-value="😮,🤩">
                        <span>😮</span>
                        <span>🤩</span>
                    </button>

                    <button type="button"
                            class="emoji-group flex gap-4 rounded-lg border border-slate-300 px-4 py-3 text-3xl hover:bg-slate-50"
                            data-selected="false"
                            data-value="😻,😹">
                        <span>😻</span>
                        <span>😹</span>
                    </button>

                    <button type="button"
                            class="emoji-group flex gap-4 rounded-lg border border-slate-300 px-4 py-3 text-3xl hover:bg-slate-50"
                            data-selected="false"
                            data-value="☺️,😀">
                        <span>☺️</span>
                        <span>😀</span>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
