@model IntegratieProject.UI.MVC.Models.CreateProjectIdeationViewModel

@{
    ViewBag.Title = "Nieuw project aanmaken";
    Layout = "_Layout";
}

<div class="admin-page">

    <div class="admin-header">
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="SubAdmin"
               asp-action="Index"
               asp-route-subplatform="@Model.SubplatformSlug"
               class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center"
               style="width:38px;height:38px;border-radius:8px;">
                ←
            </a>
            <div>
                <h1 class="admin-title">Nieuw project aanmaken</h1>
                <span class="badge bg-secondary">Draft</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary">Preview</button>
            <button type="submit" form="ideationForm" class="btn btn-primary">Opslaan</button>
        </div>
    </div>

    <nav class="admin-tabs mb-4">
        <a asp-controller="SubAdminProjects"
           asp-action="ProjectInfo"
           asp-route-subplatform="@Model.SubplatformSlug"
           class="admin-tab-link">Project Info</a>
        <a asp-controller="SubAdminProjects"
           asp-action="CreateSurvey"
           asp-route-subplatform="@Model.SubplatformSlug"
           class="admin-tab-link">Bevraging</a>
        <button type="button" class="admin-tab-link active">Ideation</button>
    </nav>

    <form id="ideationForm"
          asp-controller="SubAdminProjects"
          asp-action="SaveIdeation"
          asp-route-subplatform="@Model.SubplatformSlug"
          method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        @if (TempData["IdeationSavedMessage"] is string savedMessage)
        {
            <div class="alert alert-success">@savedMessage</div>
        }

        <div class="admin-form-card">
            <h2 class="admin-form-title">Ideation Topics</h2>
            <p class="admin-form-subtitle">
                Stel de topics in waarvoor jongeren ideeën kunnen geven. Dit kan 1 topic zijn, maar ook meerdere.
            </p>

            <div id="topicsContainer">
                @for (var i = 0; i < Model.Topics.Count; i++)
                {
                    <div class="topic-card" data-index="@i">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="topic-number">Topic @(i + 1)</div>
                            <button type="button"
                                    class="remove-topic-btn btn btn-outline-danger btn-sm">
                                🗑️
                            </button>
                        </div>

                        <div class="mb-3">
                            <input name="Topics[@i].Title"
                                   id="Topics_@(i)__Title"
                                   value="@Model.Topics[i].Title"
                                   class="topic-title form-control"
                                   placeholder="bv. Acties om mentaal welzijn te verbeteren" />
                            <span class="topic-title-validation text-danger small"
                                  data-valmsg-for="Topics[@i].Title"
                                  data-valmsg-replace="true"></span>
                        </div>

                        <div>
                            <textarea name="Topics[@i].Description"
                                      id="Topics_@(i)__Description"
                                      rows="3"
                                      class="topic-description form-control"
                                      placeholder="Beschrijving/context voor dit topic (optioneel)...">@Model.Topics[i].Description</textarea>
                            <span class="topic-description-validation text-danger small"
                                  data-valmsg-for="Topics[@i].Description"
                                  data-valmsg-replace="true"></span>
                        </div>
                    </div>
                }
            </div>

            <button type="button"
                    id="addTopicButton"
                    class="btn btn-outline-secondary btn-sm mt-2">
                + Topic toevoegen
            </button>
        </div>

        <div class="admin-form-card">
            <div class="d-flex align-items-center gap-2 mb-1">
                <h2 class="admin-form-title mb-0">AI Doorvraag Prompts</h2>
                <span class="badge bg-light text-muted border">?</span>
            </div>
            <p class="admin-form-subtitle">
                AI stelt gerichte vragen om ideeën te verdiepen. Pas de prompt aan voor betere context.
            </p>

            <div class="mb-3">
                <label asp-for="ProjectContext" class="form-label">Context over het project</label>
                <textarea asp-for="ProjectContext"
                          rows="5"
                          class="form-control"
                          placeholder="bv. Dit gaat over een hogeschool die haar studenten (17-25 jaar) wil ondersteunen..."></textarea>
                <span asp-validation-for="ProjectContext" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="IdeaInfo" class="form-label">Gewenste informatie over ideeën</label>
                <textarea asp-for="IdeaInfo"
                          rows="5"
                          class="form-control"
                          placeholder="bv. We willen weten: Wie organiseert het? Hoe vaak? Wat kost het? Hoe bereik je studenten?..."></textarea>
                <span asp-validation-for="IdeaInfo" class="text-danger small"></span>
            </div>
        </div>

        <div class="admin-form-card">
            <h2 class="admin-form-title">AI-selectie instellingen</h2>
            <p class="admin-form-subtitle">Stel in hoeveel ideeën tegelijk getoond worden.</p>

            <div class="row">
                <div class="col-12 col-md-6">
                    <label asp-for="IdeasPerBatch" class="form-label">Aantal ideeën per keer</label>
                    <input asp-for="IdeasPerBatch"
                           type="number"
                           min="3"
                           max="10"
                           class="form-control" />
                    <span asp-validation-for="IdeasPerBatch" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="admin-form-card">
            <h2 class="admin-form-title">Reacties</h2>
            <p class="admin-form-subtitle">Kies de emoji-groep die je wilt tonen bij ideeën.</p>

            <input asp-for="SelectedEmojiGroup" type="hidden" id="SelectedEmojiGroup" />

            <div id="emojiGroups" class="d-flex flex-column gap-2">
                <button type="button"
                        class="emoji-group"
                        data-selected="false"
                        data-value="😮,🤩">
                    <span>😮</span>
                    <span>🤩</span>
                </button>
                <button type="button"
                        class="emoji-group"
                        data-selected="false"
                        data-value="😻,😹">
                    <span>😻</span>
                    <span>😹</span>
                </button>
                <button type="button"
                        class="emoji-group"
                        data-selected="false"
                        data-value="☺️,😀">
                    <span>☺️</span>
                    <span>😀</span>
                </button>
            </div>
        </div>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const buttons = document.querySelectorAll(".emoji-group");
            const hiddenInput = document.getElementById("SelectedEmojiGroup");

            buttons.forEach(button => {
                button.addEventListener("click", function () {
                    buttons.forEach(b => { b.dataset.selected = "false"; });
                    this.dataset.selected = "true";
                    hiddenInput.value = this.dataset.value;
                });
            });

            const defaultButton =
                document.querySelector('.emoji-group[data-value="' + hiddenInput.value + '"]')
                || buttons[0];

            if (defaultButton) { defaultButton.click(); }
        });
    </script>
}
