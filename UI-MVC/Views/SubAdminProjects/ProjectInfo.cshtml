@using IntegratieProject.BL.Domain.project
@using IntegratieProject.UI.MVC.Models
@model IntegratieProject.UI.MVC.Models.CreateProjectInfoViewModel

@{
    ViewBag.Title = "Nieuw project aanmaken";
    Layout = "_AdminLayout";
}

<div class="admin-page">

    <div class="admin-header">
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="SubAdmin"
               asp-action="Index"
               asp-route-subplatform="@Model.SubplatformSlug"
               class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center"
               style="width:38px;height:38px;border-radius:8px;">
                ←
            </a>
            <div>
                <h1 class="admin-title">Nieuw project aanmaken</h1>
                <span class="badge bg-secondary">Draft</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" form="createProjectForm" class="btn btn-primary">Opslaan</button>
        </div>
    </div>

    <nav class="admin-tabs mb-4">
        <button type="button" class="admin-tab-link active">Project Info</button>
        <button type="submit"
                form="createProjectForm"
                name="nextAction"
                value="CreateSurvey"
                class="admin-tab-link">
            Bevraging
        </button>

        <button type="submit"
                form="createProjectForm"
                name="nextAction"
                value="CreateIdeation"
                class="admin-tab-link">
            Ideation
        </button>
    </nav>

    <form id="createProjectForm"
          asp-controller="SubAdminProjects"
          asp-action="Create"
          asp-route-subplatform="@Model.SubplatformSlug"
          method="post"
          enctype="multipart/form-data"
          data-subplatform="@Model.SubplatformSlug">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="admin-form-card">
            <h2 class="admin-form-title">Basisinformatie</h2>
            <p class="admin-form-subtitle">Geef je project een naam en een visuele identiteit.</p>

            <div class="mb-4">
                <label asp-for="Name" class="form-label">
                    Projectnaam <span class="text-danger">*</span>
                </label>
                <input asp-for="Name"
                       class="form-control"
                       placeholder="bijv. Actieplan mentaal welzijn 2026"/>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="IntroMediaUpload" class="form-label">Introductie media</label>

                <input asp-for="IntroMediaUri" type="hidden" id="IntroMediaUri"/>

                <div class="mb-2">
                    <label class="form-label small text-muted">Kies type media</label>
                    <select asp-for="IntroMediaType" class="form-select">
                        <option value="Image">Afbeelding</option>
                        <option value="Video">Video</option>
                    </select>
                </div>

                <div class="upload-zone">
                    <span class="upload-icon">🖼️</span>

                    <label for="IntroMediaUpload" class="btn btn-primary btn-sm mb-2">
                        Upload afbeelding of video
                    </label>

                    <input asp-for="IntroMediaUpload"
                           id="IntroMediaUpload"
                           type="file"
                           class="d-none"
                           accept="image/jpeg,image/png,image/webp,video/mp4,video/webm,video/quicktime"/>
                    
                    <div class="text-muted small mb-2">of</div>

                    <button type="button"
                            id="generateProjectImageButton"
                            class="btn btn-outline-primary btn-sm">
                        ✨ Genereer afbeelding met AI
                    </button>

                    <p id="projectImageStatus" class="text-muted small mt-3 mb-3">
                        Je kan hier een afbeelding of video toevoegen. Als je geen afbeelding uploadt,
                        kan AI automatisch een afbeelding genereren.
                    </p>

                    <div id="introMediaUploadStatus"
                         class="alert alert-success py-2 px-3 small d-none mb-3"
                         role="status"></div>

                    <img id="projectImagePreview"
                         src="@Model.IntroMediaUri"
                         alt="Project afbeelding preview"
                         class="img-fluid rounded border @(string.IsNullOrWhiteSpace(Model.IntroMediaUri) ? "d-none" : "")"
                         style="max-height: 220px; object-fit: cover;"/>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Introduction" class="form-label">
                    Introductietekst <span class="text-danger">*</span>
                </label>
                <div class="border rounded overflow-hidden">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                         <span class="small text-body-secondary fw-semibold">Tekstinhoud</span>
                        <button type="button"
                                id="generateIntroductionButton"
                                class="btn btn-outline-primary btn-sm">
                            ✨ AI hulp
                        </button>
                    </div>
                    <textarea asp-for="Introduction"
                              rows="8"
                              class="form-control border-0 rounded-0"
                              placeholder="Schrijf hier de introductie voor jongeren..."></textarea>
                </div>
                <span asp-validation-for="Introduction" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Duration" class="form-label">
                    Tijdsduur in minuten <span class="text-danger">*</span>
                </label>
                <input asp-for="Duration"
                       type="number"
                       min="1"
                       class="form-control"
                       placeholder="bijv. 10"/>
                <span asp-validation-for="Duration" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="FontFamily" class="form-label">
                    Lettertype <span class="text-danger">*</span>
                </label>
                <div class="row g-3 align-items-stretch">
                    <div class="col-12 col-md-6">
                        <select asp-for="FontFamily" class="form-select" id="FontFamily">
                            @foreach (var fontFamily in CreateProjectInfoViewModel.AllowedFontFamilies)
                            {
                                <option value="@fontFamily"
                                        data-font-stack="@ProjectFontFamily.ToCssStack(fontFamily)">
                                    @(fontFamily == CreateProjectInfoViewModel.DefaultFontFamily ? $"{fontFamily} (default)" : fontFamily)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <div id="fontPreview"
                             class="border rounded px-3 py-2 bg-body-tertiary text-body-emphasis h-100 d-flex align-items-center"
                             style="font-family: @ProjectFontFamily.ToCssStack(Model.FontFamily);">
                            Dit is een voorbeeld zin.
                        </div>
                    </div>
                </div>
                <span asp-validation-for="FontFamily" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ColorTheme" class="form-label">
                    Kleurthema <span class="text-danger">*</span>
                </label>

                <div class="theme-select-wrapper">
                    <div id="themePreview"
                         class="theme-select-preview"
                         style="background: linear-gradient(135deg, @ProjectColorTheme.GetPrimaryColor(Model.ColorTheme) 0%, @ProjectColorTheme.GetDarkColor(Model.ColorTheme) 100%);">
                    </div>

                    <select asp-for="ColorTheme"
                            class="form-select theme-select" >
                        @foreach (var theme in CreateProjectInfoViewModel.AllowedColorThemes)
                        {
                            <option value="@theme"
                                    data-primary="@ProjectColorTheme.GetPrimaryColor(theme)"
                                    data-dark="@ProjectColorTheme.GetDarkColor(theme)">
                                @theme
                            </option>
                        }
                    </select>
                </div>

                <span asp-validation-for="ColorTheme" class="text-danger small d-block mt-2"></span>
            </div>

            <div>
                <h3 class="admin-form-title mb-1">Vorm van het project</h3>
                <p class="admin-form-subtitle">Kies hoe deelnemers de vragen beantwoorden.</p>

                <div class="type-selector-grid">
                    <label class="project-type-label">
                        <input asp-for="Type" type="radio" value="@ProjectType.Chat"/>
                        <div class="project-type-card">
                            <div class="type-icon">💬</div>
                            <h3>Chat-vorm</h3>
                            <p>Vragen verschijnen als chat-berichten. Interactief en conversationeel.</p>
                        </div>
                    </label>

                    <label class="project-type-label">
                        <input asp-for="Type" type="radio" value="@ProjectType.VerticalScroll"/>
                        <div class="project-type-card">
                            <div class="type-icon">↕️</div>
                            <h3>Verticale scroll-vorm</h3>
                            <p>Doorheen vragen scrollen in één doorlopende flow.</p>
                        </div>
                    </label>
                </div>

                <span asp-validation-for="Type" class="text-danger small d-block mt-2"></span>
            </div>
        </div>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
